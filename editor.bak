Paragraf uzunlugu: 3-5 cumle ideal, 8i gecme.

===========================================================
KURAL 6: GEZILECEK YERLER H2 - OZEL KURAL
===========================================================
"Gezilecek Yerler" basligi iceren H2 bolumunde:
1. Bos H2 altina 2 paragraf ozet yaz (bolge ozeti + tavsiye)
2. Her H3 = ayri bir yer: "1. Yer Adi - Kisa tanitim" formati
3. Her H3 altinda 2-3 paragraf (karakter, one cikan, pratik)
4. Sadece virgullu anahtar kelime listesi varsa -> paragrafa donustur
5. Numarali ama bos H3 varsa -> baslik olustur + doldur
6. Her H3 ARASINA ve sonuna separator ekle
"""


# ============================================================
# GUIDE_TRAINING — Gezi Rehberi formatı için training
# ============================================================
GUIDE_GIRIS_TRAINING = GIRIS_TRAINING  # Ortak — WHERE/TRAVEL/GUIDE aynı giriş kuralı

GUIDE_GEZILECEK_TRAINING = """
GUIDE MOD GEZİLECEK YERLER

H3 FORMAT (ZORUNLU):
{Sıra}. {Yer Adı} - {Kısa tanıtım}

Örnek:
### 1. Senso-ji Tapınağı - Tokyo'nun en eski Budist tapınağı

Her H3 için 2-3 paragraf:
1. PARAGRAF: Konum, ulaşım, tarih, mimari
2. PARAGRAF: İçinde ne var, neden görülmeli, dikkat çekici bölümler
3. PARAGRAF (opsiyonel): Pratik bilgiler (giriş ücreti, saatler, süre), çevre gezilecekler

Her H3 arasına separator:
<!-- wp:separator -->
<hr class="wp-block-separator has-alpha-channel-opacity"/>
<!-- /wp:separator -->
→ bkz. DIL_KURALLARI (yasak kelimeler, bold, anlatım)
"""


def revise_where_post(post):
    """
    Where.txt uygulama sırası (§15):
    ADIM 1: Giriş paragrafları (Claude, Anlatı mimarisi)
    ADIM 2: İlk fotoğraf
    ADIM 3: Kişisel bakış/yorum paragrafı (Claude)
    ADIM 4: HR + H2 "Nasıl Bir Yer" + Gezilecek Yerler
    ADIM 5: HR + H2 "Nerede" + 2 paragraf + Maps box
    ADIM 6: HR + H2 "Nasıl Gidilir" + 2.-3. fotoğraflar
    ADIM 7: Uçak bileti link listesi
    ADIM 8: HR + Gezi Planı + HR + Kapanış paragrafları
    ADIM 9: Schema + FAQ
    ADIM 10: Yorum + Yoast SEO → WP güncelle
    """
    pid     = post['id']
    title   = post['title']['rendered']
    content = post['content']['rendered']

    dest     = extract_dest(title)
    today    = datetime.now().strftime('%Y-%m-%d')
    flag     = get_flag(dest)

    # Orijinal kategorileri al (WP güncelleme + yerel kayıt için)
    try:
        orig_cats = get_post_categories(pid)
        cat_slug  = get_category_path(orig_cats[0]) if orig_cats else 'draft'
    except Exception:
        orig_cats, cat_slug = [], 'draft'
    is_where = is_where_post(title)

    engine_names = {"claude": "Claude Sonnet 4.5", "gpt": "GPT-4o (4x key)",
                    "auto": "Auto (Claude → GPT)"}
    engine = engine_names.get(AI_ENGINE, AI_ENGINE)
    is_gpt = AI_ENGINE in ("gpt", "auto")
    print("\n   📊 ENGINE ROUTING:")
    print(f"      🔵 Claude : ADIM 1 (giriş 2§) — AI_ENGINE'den bağımsız")
    print(f"      🔵 Claude : ADIM 3 (kişisel bakış) — AI_ENGINE'den bağımsız")
    print(f"      {'🟢 GPT-4o' if is_gpt else '🔵 Claude'} : ADIM 4/5/6 (nasıl bir yer/nerede/nasıl gidilir)")
    print(f"      {'🟢 GPT-4o' if is_gpt else '🔵 Claude'} : ADIM 8 (gezi planı), Maps box JSON")
    print(f"      🟢 GPT-4o : ADIM 9 (FAQ+Schema) — AI_ENGINE'den bağımsız")
    _tasarruf = "~%20 (GPT-4o Claude Sonnet'tan ucuz)" if is_gpt else "%0 (--ai gpt ekle)"
    print(f"      💡 Tahmini tasarruf: {_tasarruf}\n")
    print(f"\n🚀 WHERE MODE: {dest} {flag}")
    print(f"   📦 Post ID: {pid}  |  🤖 {engine}")
    print(f"   📌 WHERE: {'Evet' if is_where else 'Hayır — H1 korunacak'}\n")

    # ── Ön hazırlık: Gutenberg sıyır ────────────────────────────────────
    content = strip_gutenberg(content)

    # ── BOX + ESKİ MAPS TEMİZLİĞİ ───────────────────────────────────────
    print("   🗑️  Gereksiz içerik temizleniyor...")
    content = re.sub(r'<p[^>]*style="background-color:[^"]*"[^>]*>.*?</p>',
                     '', content, flags=re.DOTALL|re.IGNORECASE)
    content = re.sub(r'<p[^>]*class="has-background"[^>]*>.*?</p>',
                     '', content, flags=re.DOTALL|re.IGNORECASE)
    content = re.sub(r'<p[^>]*(?:ceebfd|cdfbe9)[^>]*>.*?</p>',
                     '', content, flags=re.DOTALL|re.IGNORECASE)
    # Eski styled div kutular (airbnb vs)
    content = re.sub(
        r'<div[^>]*style="[^"]*(?:background|border-radius)[^"]*"[^>]*>(?:(?!</div>).)*?</div>',
        '', content, flags=re.DOTALL|re.IGNORECASE
    )
    # Eski Google Maps iframe
    content = re.sub(r'<iframe[^>]*maps[^>]*>.*?</iframe>', '',
                     content, flags=re.DOTALL|re.IGNORECASE)
    # Eski uçak bileti H3'leri
    content = re.sub(
        r'<h3[^>]*>.*?[Uu]çak [Bb]ileti.*?</h3>.*?(?=<h[23]|$)',
        '', content, flags=re.DOTALL|re.IGNORECASE
    )
    print("      ✅ Temizlendi")

    # ── H2 başlık normalizasyonu ──────────────────────────────────────────
    # "Hakkında Kısa Bilgiler" → "Nasıl Bir Yer" (Where.txt §4)
    content = re.sub(
        r'(<h2[^>]*>.*?)(Hakkında Kısa Bilgiler|Hakkinda Kisa Bilgiler)(.*?</h2>)',
        r'\1Nasıl Bir Yer\3',
        content, flags=re.IGNORECASE|re.DOTALL
    )

    # ── Resimleri çıkar (sonra yeniden yerleştireceğiz) ─────────────────
    images = extract_all_images(content)
    content = remove_all_images(content)
    print(f"   🖼️  {len(images)} resim çıkarıldı (yeniden yerleştirilecek)")

    # ── Gezilecek Yerler çıkar ──────────────────────────────────────────
    gezilecek_html = ""
    gm = re.search(r'(<h3[^>]*>.*?gezilecek yerler.*?</h3>.*?)(?=<h[23]|<script|$)',
                   content, re.IGNORECASE|re.DOTALL)
    if gm:
        gezilecek_html = gm.group(1).strip()
        # H3 'Gezilecek Yerler 📌' başlığını sil — içerik kalacak
        gezilecek_html = re.sub(
            r'<h[23][^>]*>.*?[Gg]ezilecek\s+[Yy]erler.*?</h[23]>\s*',
            '', gezilecek_html, flags=re.DOTALL
        ).strip()
        content = content.replace(gm.group(1).strip(), '')
        print("   📌 Gezilecek Yerler çıkarıldı (başlık silindi, içerik korundu)")

    original_paras = len(re.findall(r'<p>', content))
    print(f"   📊 Orijinal: {original_paras} paragraf\n")

    # ════════════════════════════════════════════════════════════════════
    # ADIM 1: GİRİŞ PARAGRAFLARI (Where.txt §1 — Claude, Anlatı Mimarisi)
    # Orijinal girişi referans al, Anlatı Mimarisine göre YENIDEN YAZ
    # ════════════════════════════════════════════════════════════════════
    print("   🔵 ADIM 1: Giriş paragrafları (Claude — Anlatı Mimarisi)...")
    # Orijinal içerikten ilk 2 paragrafı al (referans için)
    _orig_p = re.findall(r'<p[^>]*>.*?</p>', content, re.DOTALL)
    _orig_giris = "\n".join(_orig_p[:2]) if _orig_p else ""
    giris_prompt = f"""SEN: yoldaolmak.com yazari Kemal Kaya.
GOREV: {dest} {flag} icin ilk 2 giris paragrafi — ASAGIDAKI ORIJINAL METNI YENIDEN YAZ.

{GIRIS_TRAINING}

ORIJINAL GİRİŞ (bilgileri koru, dili ve tonu TEMELDEN yeniden yaz):
{_orig_giris if _orig_giris else "(Mevcut giriş yok — sıfırdan yaz)"}

CIKTI: Sadece 2 adet <p>...</p>. Fazlasi degil."""
    giris_raw = ask_claude_only(giris_prompt, max_tokens=1500)   # Claude (AI_ENGINE'den bağımsız)
    giris_raw = clean_html(giris_raw)
    giris_raw = fix_md_bold_italic(giris_raw)
    giris_raw = auto_fix_gpt_output(giris_raw)   # tire + yasak kelime otofiks
    # Kalıp kontrolü
    kalip_issues = check_giris_kalip(giris_raw, dest)
    if kalip_issues:
        import random as _rnd
        # Farklı bir açılış tipi zorla — dict double-quote güvenli
        _tip_c = "Ilk fark ettiğim şey deniz değildi. " + dest + " başka bir şeyle vurdu:"
        _tip_d = "Şehrin tepesinde yanlış bir sokağa saptım. Bir kapı aralığından"
        _tip_e = "Kaç kişi " + dest + " için sadece bir gecelik plan yapmış, sabah planı değiştirmiştir?"
        zorunlu_tip, ornek = _rnd.choice([("C", _tip_c), ("D", _tip_d), ("E", _tip_e)])
        giris_prompt_retry = (
            giris_prompt
            + "\n\n⚠️ RETRY — ÖNCEKİ DENEME KALIP KULLANDIĞI İÇİN RED EDİLDİ.\n"
            + "ZORUNLU: Mutlaka TİP " + zorunlu_tip + " kullan.\n"
            + "İLK CÜMLE bu yapıyla başlamalı (sözcükleri değiştir):\n"
            + "\u2192 \"" + ornek + "\"\n"
            + "KALIP: \"" + dest + "'e gelmeden herkes...\" ve \"Haklıydılar\" KESINLIKLE YASAK.\n"
        )
        print(f"      ⚠️  KALIP TESPİT: {', '.join(kalip_issues[:3])}")
        print(f"      🔄  TİP {zorunlu_tip} zorlanarak yeniden üretiliyor...")
        giris_raw = ask_claude_only(giris_prompt_retry, max_tokens=1500)  # Claude
        giris_raw = clean_html(giris_raw)
        giris_raw = fix_md_bold_italic(giris_raw)
    # auto_fix_gpt_output zaten yasak kelimeleri temizledi — check_banned sadece sanity log
    _banned = check_banned(giris_raw)
    if _banned:
        print(f"      ⚠️  Yasak kelime log: {', '.join(_banned[:3])}")
    print("      ✅ Giriş hazır")

    # ════════════════════════════════════════════════════════════════════
    # ADIM 2: İLK FOTOĞRAF (giriş paragraflarından sonra, Where.txt §2)
    # ════════════════════════════════════════════════════════════════════
    first_img_html = ""
    if images:
        img = images[0]
        first_img_html = img_wrapper(img['src'], img['alt'] or f"{dest} fotoğraf")
        print(f"   🖼️  ADIM 2: İlk fotoğraf yerleştirildi ({img['src'][:50]}...)")
    else:
        print("   ⚠️  ADIM 2: Fotoğraf bulunamadı")

    # ════════════════════════════════════════════════════════════════════
    # ADIM 3: KİŞİSEL BAKIŞ (fotoğraftan sonra, Where.txt §3 — Claude)
    # ════════════════════════════════════════════════════════════════════
    print("   💬 ADIM 3: Kişisel bakış (Claude)...")
    kisisel_prompt = f"""SEN: yoldaolmak.com yazari Kemal Kaya.
GOREV: {dest} icin giris sonrasi 2 paragraf (kisisel bakis + pratik degerlendirme).

{GIRIS_SONRASI_TRAINING}

CIKTI: 2 adet <p>...</p>."""
    kisisel_raw = ask_claude_only(kisisel_prompt, max_tokens=800)  # Kişisel bakış
    kisisel_raw = clean_html(kisisel_raw)
    kisisel_raw = fix_md_bold_italic(kisisel_raw)
    print("      ✅ Kişisel bakış hazır")

    # ════════════════════════════════════════════════════════════════════
    # ADIM 4: H2 "NASIL BİR YER" bölümü (Where.txt §5)
    # ════════════════════════════════════════════════════════════════════
    print(f"   🌍 ADIM 4: 'Nasıl Bir Yer' bölümü ({engine})...")
    
    # Türkiye kontrolü
    _is_turkey_nasil = (flag == '')
    _turkey_note_nasil = ""
    if _is_turkey_nasil:
        _turkey_note_nasil = (
            "\n\n🚫 TÜRKİYE DESTİNASYONU:\n"
            "   ❌ Saat dilimi, UTC bilgisi YAZMA\n"
            "   ❌ Vize, pasaport gereksinimleri YAZMA\n"
            "   ❌ Saat farkı YAZMA\n"
            "   ❌ Türk vatandaşı için yerel bilgiler YAZMA\n"
        )
    
    nasil_bir_yer_prompt = f"""{ULTRA_TRAINING}
{_turkey_note_nasil}

GÖREV: {dest} {flag} için "NASIL BİR YER" bölümü yaz/düzenle

BAŞLIK: <h2 class="wp-block-heading"><strong>{dest} Nasıl Bir Yer {flag}</strong></h2>

SIRA:
1. KONUM: Coğrafi lokasyon, ülke/bölge/nehir/dağ/deniz ilişkisi, rakım, iklim (kısa)
2. TARİH: Kuruluş, medeniyet katmanları, mimari izler (kısa, öz, anlatı dili)
3. KARAKTER (Genius Loci):
   - Şehrin ruhu
   - Dokusu, ışığı
   - Zaman algısı
   - İnsanı

NOT: Gezilecek yerler listesi BU BÖLÜMÜN SONUNDA ayrı bir H3 altında eklenecek.
     Ulaşım bilgisi bu bölüme YAZILMAZ.

MEVCUT İÇERİK (harmanlayarak kullan):
{content}

ZORUNLU:
- Her paragrafta 1-2 <strong>bold</strong>
- 2-3 özel isim için <em>italik</em>
- Tire (— veya –) YOK
- Yasak kelimeler YOK
- EN AZ 4-5 paragraf

GPT YASAK KALIPLAR:
❌ "adeta bir zaman yolculuğuna çıkarıyor" — KLİŞE
❌ "zaman yavaş akıyor" — KLİŞE
❌ "her köşe başında tarihin izlerini hissedebilirsiniz" — KLİŞE
❌ "misafirperver" — YASAK KELIME
❌ "şehrin ruhu sokaklarda hissedilebiliyor" — BELİRSİZ

BUNUN YERİNE:
✅ Venedik/Osmanlı/vs. hangi medeniyet bıraktığını somut yap
✅ Spesifik yapı, koku, ses, doku ile çiz
✅ Nüfus/büyüklük/tempo hakkında somut bilgi

ÇIKTI: H2 + paragraflar (HTML, not/açıklama yok):
"""
    nasil_bir_yer = safe_gpt(nasil_bir_yer_prompt, content,
                             max_tokens=2000, min_chars=500)  # Token optimizasyonu

    # Gezilecek Yerleri bu bölümün sonuna ekle (anlatı içinde, liste DEĞİL)
    if gezilecek_html:
        nasil_bir_yer += "\n\n" + gezilecek_html
        print("      📌 Gezilecek Yerler eklendi")
    print("      ✅ Nasıl Bir Yer hazır")

    # ════════════════════════════════════════════════════════════════════
    # ADIM 5: H2 "NEREDE" bölümü + Maps (Where.txt §6)
    # G3: Türkiye filtresi / G7: GPT'ye devredildi
    # ════════════════════════════════════════════════════════════════════
    print(f"   📍 ADIM 5: 'Nerede' bölümü (GPT)...")
    _is_turkey = (get_flag(dest) == '')
    if _is_turkey:
        _nerede_p2 = (
            "Türkiye içindeki coğrafi konumu: hangi bölgede, yakın şehirler, "
            "nehir/dağ/deniz ilişkisi (kısa). Ardından: bu destinasyonun tarihi önemi — "
            "hangi medeniyetler burada yaşadı, neden stratejik önem taşıdı, "
            "günümüzde neden ünlü (somut, anlatı dili)"
        )
        _turkey_note = (
            "\n🚫 KESINLIKLE YAZMA: saat dilimi, UTC, vize, pasaport kontrolü, "
            "Türk vatandaşı için gereksinimler — BUNLAR TÜRKİYE DESTİNASYONLARINDA ANLAMSIZ."
        )
    else:
        _nerede_p2 = "Yüzölçümü, rakım, saat dilimi (UTC+X), vize/pasaport (Türk vatandaşı için), tarihî önem"
        _turkey_note = ""

    if _is_turkey:
        _turkey_block = (
            "\n🚫 TÜRKİYE DESTİNASYONU — KESINLIKLE YAZMA (anlamsız):\n"
            "   saat dilimi, UTC, vize, pasaport kontrolü, gümrük, Türk vatandaşı gereksinimleri\n"
        )
        _p2_directive = (
            "PARAGRAF 2 — COĞRAFİ ÖNEMİN TARİHSEL SONUÇLARI:\n"
            "Bu konumun coğrafyası hangi medeniyetleri buraya çekti?\n"
            "Ticaret yolu kavşağı mıydı, dini merkez miydi, askeri üs müydü?\n"
            "Konum bugün şehrin kimliğini nasıl şekillendiriyor?\n"
            "Somut: hangi medeniyetler, hangi yapılar, hangi kırılma noktaları."
        )
    else:
        _turkey_block = ""
        _p2_directive = (
            "PARAGRAF 2 — COĞRAFİ ÖNEMİN TARİHSEL SONUÇLARI:\n"
            "Bu konumun coğrafyası (deniz/nehir/dağ/yol) tarihi nasıl şekillendirdi?\n"
            "Hangi medeniyetler bu yüzden buraya değer verdi?\n"
            "Saat dilimi (UTC+X), vize/pasaport (Türk vatandaşı için) kısa not olarak ekle.\n"
            "Somut: hangi ticaret yolu, hangi imparatorluk, hangi dönem dönüşümü."
        )

    nerede_prompt = (
        f"{_turkey_block}\n"
        + ULTRA_TRAINING + "\n\n"
        + f'GÖREV: {dest} için "NEREDE" bölümü yaz\n\n'
        + f'BAŞLIK: <h2 class="wp-block-heading"><strong>{dest} Nerede 📍</strong></h2>\n\n'
        + "PARAGRAF 1 — COĞRAFİ KONUM:\n"
        + "Ülke, bölge, nehir/dağ/deniz ilişkisi, komşu şehirler/ülkeler, rakım/yüzölçüm (kısa).\n\n"
        + _p2_directive + "\n\n"
        + "🚫 KESİNLİKLE YASAK: Koordinat, enlem, boylam, derece (°)\n"
        + "Her paragrafta 1-2 bold. Tire yok.\n\n"
        + "ÇIKTI: H2 + 2 adet <p>...</p>"
    )
    nerede_raw = safe_gpt(nerede_prompt, "", max_tokens=1200, min_chars=200)

    # Zengin harita kutusu
    maps_box = get_rich_maps_box(dest)
    nerede_section = nerede_raw + "\n\n" + maps_box
    print("      🗺️  Zengin harita kutusu eklendi")
    print("      ✅ Nerede hazır")

    # ════════════════════════════════════════════════════════════════════
    # ADIM 6: H2 "NASIL GİDİLİR" + 2.-3. fotoğraflar (Where.txt §7 & §8)
    # ════════════════════════════════════════════════════════════════════
    print(f"   ✈️  ADIM 6: 'Nasıl Gidilir' bölümü ({engine})...")
    
    # Türkiye kontrolü - ulaşım bilgileri için
    _is_turkey_nasil_gid = (flag == '')
    if _is_turkey_nasil_gid:
        _ulasim_directive = (
            "\n\n🚫 TÜRKİYE DESTİNASYONU:\n"
            "   ❌ 'İstanbul'dan' yerine 'Türkiye'den' veya şehir adlarını kullan\n"
            "   ❌ Vize, pasaport kontrolü, gümrük bilgisi YAZMA\n"
            "   ❌ Saat farkı YAZMA\n"
            "   ✅ Türkiye içi ulaşım odaklı yaz: otobüs, uçak, özel araç, tren (varsa)\n"
        )
        _ulasim_kapsam = (
            "- Uçak: Türkiye'nin hangi şehirlerinden uçuş var, havalimanı adı, kaç saat\n"
            "- Otobüs: Hangi şehirlerden, terminal adı, kaç saat\n"
            "- Özel araç: Hangi yollar, kaç km, kaç saat\n"
            "- Tren: Sadece gerçekten varsa\n"
            "- Şehir içi: Otogar/havalimanından merkeze ulaşım"
        )
    else:
        _ulasim_directive = ""
        _ulasim_kapsam = (
            "- Uçak: Hangi havalimanı (isim ver), İstanbul'dan hangi havayolları, direkt mi aktarmalı mı, kaç saat\n"
            "- Kara yolu: Otobüs kaç saat sürer, karayolu güzergahı, sınır kapısı (uluslararası ise)\n"
            "- Demir yolu: Sadece tren bağlantısı gerçekten varsa yaz\n"
            "- Deniz yolu: Sadece feribot/vapur gerçekten varsa yaz\n"
            "- Şehir içi: Havalimanından merkeze nasıl gidilir (metro/taksi/servis), yaklaşık ücret, süre"
        )
    
    nasil_gidilir_prompt = f"""{ULTRA_TRAINING}
{_ulasim_directive}

GÖREV: {dest} için "NASIL GİDİLİR" bölümü

BAŞLIK: <h2 class="wp-block-heading"><strong>{dest}'a Nasıl Gidilir ✈️</strong></h2>

KAPSAM (yalnızca gerçekten var olanları yaz — olmayan ulaşımı "yok" diye de yazma):
{_ulasim_kapsam}

KALİTE STANDARDI:
- Havalimanı adını yaz: "X Havalimanı" — "yerel havalimanı" yazma
- Uçuş süresini yaz: "yaklaşık 3 saat" — "birkaç saat" yazma
- Otobüs için terminal adını yaz (biliyorsan) ve kaç saatte varılır
- Şehir içi transferde seçenek sun: "Metro 40 dakika, taksi 25 dakika ama 3-4 kat pahalı"
- Her ulaşım türü ayrı paragraf, başında <strong>Uçak:</strong> / <strong>Otobüs:</strong> gibi etiket

ÇIKTI: H2 + paragraflar (HTML)
"""
    _nasil_raw = safe_gpt(nasil_gidilir_prompt, "", max_tokens=1500, min_chars=400)  # Token optimizasyonu
    # Gutenberg wrap — GPT çıplak paragraf döndürürse sarmalama yap
    if "<!-- wp:paragraph -->" not in _nasil_raw:
        nasil_gidilir = wrap_gutenberg(_nasil_raw)
    else:
        nasil_gidilir = _nasil_raw

    print("      ✅ Nasıl Gidilir hazır")

    # ════════════════════════════════════════════════════════════════════
    # ADIM 6b: 2. FOTOĞRAF — Uçak bileti başlığı öncesi
    # ════════════════════════════════════════════════════════════════════
    second_img_html = ""
    if len(images) >= 2:
        second_img_html = img_wrapper(
            images[1]['src'],
            images[1]['alt'] or f"{dest} havalimanı"
        )
        print(f"   🖼️  ADIM 6b: 2. fotoğraf hazır (uçak bileti öncesi)")
    else:
        print("   ⚠️  ADIM 6b: 2. fotoğraf bulunamadı")

    # ════════════════════════════════════════════════════════════════════
    # ADIM 7: UÇAK BİLETİ LİNK LİSTESİ (Where.txt §9)
    # ════════════════════════════════════════════════════════════════════
    flight_links = build_flight_links(dest)
    print("   ✈️  ADIM 7: Uçak bileti listesi hazır (SEP öncesiyle birlikte)")

    # ════════════════════════════════════════════════════════════════════
    # ADIM 8: GEZİ PLANI + KAPANIS PARAGRAFLARI (Where.txt §11 & §13)
    # ════════════════════════════════════════════════════════════════════
    print(f"   🗓️  ADIM 8: Gezi Planı ({engine})...")
    gezi_prompt = f"""{ULTRA_TRAINING}

GÖREV: {dest} için GEZİ PLANI bölümü

BAŞLIK: <h2 class="wp-block-heading"><strong>{dest} Gezi Planı 🗓</strong></h2>

- Destinasyonu gezmek için kaç gün ayırmalı (minimum/ideal/uzun)
- Önerilen gezi planı — HER GÜN 1 PARAGRAF şeklinde yaz (Gün 1, Gün 2...)
- Örnek rotalar, dikkat edilecekler

Her paragrafta 1-2 <strong>bold</strong>. Tire yok. Yasak kelime yok. Pratik, blogger tonu.

MUTLAK YASAKLAR:
❌ "kaybolmanın keyfine varın" — KLİŞE
❌ "atmosferinde kaybolun" — KLİŞE
❌ "zaman yolculuğuna çıkın" — KLİŞE
❌ "unutmayın" — HARD IMPERATIVE
❌ Tire (—) karakteri
❌ Emin olmadığın pazar/restoran/yer adı — UYDURMA (generik tut)

BUNUN YERİNE:
✅ "Eski kenti sabah erkenden gez" (soft imperative)
✅ "Birinci gün için 4-5 saat yeterli" (somut süre)

ÇIKTI: H2 + her gün 1 paragraf (HTML):
"""
    gezi_raw = ask_gpt_only(gezi_prompt, max_tokens=1200)  # Token optimizasyonu
    gezi_raw = clean_html(gezi_raw)
    gezi_raw = fix_md_bold_italic(gezi_raw)
    gezi_raw = auto_fix_gpt_output(gezi_raw)
    print("      ✅ Gezi Planı hazır")

    print(f"   📝 ADIM 8b: Kapanış paragrafları (Claude)...")
    kapanis_prompt = KAPANIS_TRAINING.replace('{dest}', dest)
    kapanis_raw = ask_gpt_only(kapanis_prompt, max_tokens=800)  # G6: GPT
    kapanis_raw = clean_html(kapanis_raw)
    kapanis_raw = fix_md_bold_italic(kapanis_raw)
    kapanis_raw = auto_fix_gpt_output(kapanis_raw)
    _kap_issues = check_giris_kalip(kapanis_raw, dest)
    if _kap_issues:
        print(f"      ⚠️  Kapanış kalıp ({_kap_issues[0]}) → yeniden üretiliyor...")
        kapanis_raw = ask_gpt_only(kapanis_prompt, max_tokens=800)  # G6: GPT
        kapanis_raw = clean_html(kapanis_raw)
        kapanis_raw = fix_md_bold_italic(kapanis_raw)
        kapanis_raw = auto_fix_gpt_output(kapanis_raw)
    print("      ✅ Kapanış hazır")

    # ════════════════════════════════════════════════════════════════════
    # ADIM 8c: YOAST META OLUŞTUR (ADIM 9 öncesinde — schema için gerekli)
    # ════════════════════════════════════════════════════════════════════
    new_title = (
        f"{dest} Nasıl Bir Yer? Nerede, Nasıl Gidilir, Gezi Planı"
        if is_where else title
    )
    yoast_title, yoast_desc = build_yoast_meta(dest)
    focuskw = f"{dest} nerede nasıl gidilir"
    print(f"   🔍 ADIM 8c: Yoast meta hazır ({len(yoast_desc)} kar.)")
    print(f"      📝 H1: {new_title}")
    print(f"      📖 Meta: {yoast_desc[:65]}...")

    # ════════════════════════════════════════════════════════════════════
    # ADIM 9: SCHEMA + FAQ (Where.txt §12)
    # ════════════════════════════════════════════════════════════════════
    schema_faq = build_faq_schema(
        dest, mode='where',
        headline=new_title,
        meta_desc=yoast_desc,
        today=today
    )
    print("   📋 ADIM 9: Schema + FAQ eklendi (WHERE mod, 7 soru)")

    # ════════════════════════════════════════════════════════════════════
    # YAPI BİRLEŞTİR (Where.txt §15 uygulama sırası)
    # ════════════════════════════════════════════════════════════════════
    sections = [
        giris_raw,                                              # §1   Giriş (2 paragraf)
        first_img_html,                                         # §2   İlk fotoğraf
        kisisel_raw,                                            # §3   Kişisel bakış
        SEP + "\n" + nasil_bir_yer,                             # §4   HR → H2 Nasıl Bir Yer
        SEP + "\n" + nerede_section,                            # §5   HR → H2 Nerede + Maps
        SEP + "\n" + nasil_gidilir,                             # §6   HR → H2 Nasıl Gidilir
        second_img_html,                                         # §7   2. fotoğraf (uçak bileti öncesi)
        SEP + "\n" + flight_links,                             # §8   HR → H3 Uçak bileti listesi
        SEP,                                                    # §10  Standalone HR
        gezi_raw,                                               # §11  H2 Gezi Planı 🗓
        SEP,                                                    # §12  Standalone HR
        kapanis_raw,                                            # §13  Kapanış (2 paragraf)
        schema_faq,                                             # §14  Schema + FAQ (HR YOK)
    ]

    # G2: Kalan fotoğrafları (3.+) bölümler arasına dağıt
    if len(images) > 2:
        sections = distribute_images(images, sections, start=2)
        print(f"   🖼️  {len(images)-2} ek fotoğraf bölümler arasına dağıtıldı")

    combined = "\n\n".join(s for s in sections if s.strip())

    # ── H başlıkları bold ────────────────────────────────────────────────
    combined = enforce_h_bold(combined)

    # ── Gutenberg bloklara çevir ─────────────────────────────────────────
    combined = wrap_gutenberg(combined)
    combined = validate_gutenberg(combined)   # G4
    combined = dedup_separators(combined)
    combined = add_flag_to_first_h2(combined, flag)
    combined = enforce_h2_emojis(combined, flag)       # S3+S4: Tüm H2 emoji kuralları
    print("   🧱 Gutenberg bloklara çevrildi")

    # ════════════════════════════════════════════════════════════════════
    # ADIM 10: WP GÜNCELLE (Where.txt §13 & §14)
    # new_title, yoast_title, yoast_desc → ADIM 8c'de hazırlandı
    # ════════════════════════════════════════════════════════════════════

    # Yerel kaydet
    os.makedirs(cat_slug, exist_ok=True)
    filename = f"{cat_slug}/{pid}-{today}-draft.html"
    with open(filename, 'w', encoding='utf-8') as f:
        f.write(combined)
    print(f"   💾 Yerel: {filename}")

    # WordPress güncelle
    print("   📤 ADIM 10: Orijinal post güncelleniyor...")
    try:
        update_post_complete(
            pid, new_title, combined,
            close_comments=True,
            update_date=True,
            yoast_title=yoast_title,
            yoast_desc=yoast_desc,
            yoast_focuskw=focuskw,
            categories=orig_cats or None
        )
        print(f"      ✅ Post ID {pid} güncellendi")
        print(f"      📝 H1:    {new_title}")
        print(f"      🔍 Yoast: {yoast_desc}")
        print(f"      🔑 kw:    {focuskw}")
        print(f"      📏 {len(yoast_desc)} karakter")
        # Ayrı PATCH: Yoast meta alanları REST API'ye kayıtlı değilse
        # ana istek silentle görmezden gelir; 2. istek bunu telafi eder
        update_yoast_meta(pid, yoast_title, yoast_desc, focuskw)
        deleted = delete_post_comments(pid)
        if deleted: print(f"      🗑️  {deleted} yorum silindi")
    except Exception as e:
        print(f"      ⚠️  WordPress hatası: {e}")

    # ── TEST KRİTERLERİ (Where.txt §TEST) ────────────────────────────────
    print("\n   📋 TEST KRİTERLERİ:")
    chk = [
        ("İlk 2 paragraf giriş + blogger tonu",  len(giris_raw) > 100),
        ("İlk fotoğraf 2. paragraf sonrası",      bool(first_img_html)),
        ("Kişisel bakış olumlu+olumsuz",          len(kisisel_raw) > 80),
        ("Ayıraç sadece H2 ÖNCESİNDE",           True),  # insert_separators yok, manuel §sections
        ("Nasıl Bir Yer: konum+tarih+karakter",   'Nasıl Bir Yer' in combined),
        ("Nerede: 2 paragraf + Maps box",          'google.com/maps' in combined),
        ("Zengin harita kutusu (wp:html)",          combined.count('wp:html') >= 1),
        ("Eski Maps kaldırıldı",                   combined.count('maps?q=') <= 1),
        ("Nasıl Gidilir genişletildi",             'Nasıl Gidilir' in combined),
        ("2. fotoğraf uçak bileti öncesinde",      len(images) < 2 or bool(second_img_html)),
        ("Resimlerden border-radius kaldırıldı",   'border-radius: 12px' not in combined or 'yoa-faq' in combined),
        ("Uçak bileti listesi (5 madde)",          flight_links.count('<li>') == 5),
        ("Gezi Planı bölümü var",                  'Gezi Plan' in combined),
        ("Kapanış 2 paragraf",                     len(kapanis_raw) > 80),
        ("Schema (Article) var",                   'Article' in combined and 'FAQPage' in combined),
        ("FAQ var (ne zaman sorusu)",               'ne zaman gidilmeli' in combined or 'ne zaman gidilir' in combined),
        ("Yoast meta desc 120-158 karakter",       120 <= len(yoast_desc) <= 158),
        ("Yoast meta desc tercihen 150+ karakter", len(yoast_desc) >= 150),
        ("Yoast başlık H1 ile aynı",               yoast_title == new_title),
        ("Dest adı meta içinde",                   dest.lower() in yoast_desc.lower()),
        ("focuskw tanımlı",                         bool(focuskw)),
        ("focuskw dest içeriyor",                   dest.lower() in focuskw.lower()),
        ("Yoast 3 alan gönderiliyor",               bool(yoast_title and yoast_desc and focuskw)),
        ("Yorumlar kapalı (WP payload)",           True),
        ("Tüm resimler wrapper ile ortalandı",     'text-align: center' in combined or not images),
    ]
    passed = sum(1 for _, v in chk if v)
    for label, ok in chk:
        print(f"      {'✅' if ok else '❌'} {label}")

    blocks = combined.count('<!-- wp:paragraph -->')
    print(f"\n✅ TAMAMLANDI: {dest} {flag}  [{passed}/{len(chk)} test]")
    print(f"   📏 {len(combined):,} karakter  |  {original_paras} para → {blocks} Gutenberg blok\n")
    return combined


# ─── DİĞER MODLAR ─────────────────────────────────────────────────────────────
def revise_travel_post(post):
    """
    TRAVEL modu — 3 ADIM:
      ADIM 1 (GPT)    : 2 paragraf giriş — Anlatı Mimarisi, hook + bağlam
      ADIM 2 (Claude) : 2 paragraf kişisel bakış — somut +/-, özgün ses
      ADIM 3 (GPT)    : Gövde — H2/H3 bölümler, Gutenberg blok formatı
    """
    content = post['content']['rendered']
    title   = post['title']['rendered']
    pid     = post.get('id', '?')
    today   = datetime.now().strftime('%Y-%m-%d')

    # Orijinal kategorileri al — tam hiyerarşik yol (turkiye/akdeniz/isparta)
    try:
        orig_cats = get_post_categories(pid) if isinstance(pid, int) else []
        cat_slug  = get_category_path(orig_cats[0]) if orig_cats else "draft"
    except Exception:
        orig_cats, cat_slug = [], "draft"

    print(f"\n   📌 Başlık: {title}")
    print(f"   📦 Post ID: {pid}  |  Orijinal: {len(content):,} char\n")

    # ── Orijinal HTML sıyır ───────────────────────────────────────────────
    raw = re.sub(r'<!-- /?wp:[^>]+ -->', '', content)
    raw = re.sub(r'<hr[^>]*/>', '', raw)
    raw = re.sub(r'\n{3,}', '\n\n', raw).strip()

    # ── M4: Renkli arka plan kutularını temizle ───────────────────────────
    # style='background-color:...' veya class='has-background' içeren bloklar
    raw = re.sub(
        r'<p[^>]+background-color[^>]*>.*?</p>', '', raw,
        flags=re.DOTALL|re.IGNORECASE
    )
    raw = re.sub(
        r'<p[^>]+has-background[^>]*>.*?</p>', '', raw,
        flags=re.DOTALL|re.IGNORECASE
    )
    raw = re.sub(
        r'<div[^>]+(?:background-color|has-background)[^>]*>.*?</div>', '', raw,
        flags=re.DOTALL|re.IGNORECASE
    )

    # ── M3: Google Maps iframe tespiti ve kaldırma ───────────────────────
    _has_orig_maps = bool(re.search(r'google[.]com/maps', raw, re.IGNORECASE))
    raw = re.sub(
        r'<figure[^>]*>\s*<iframe[^>]*google[.]com/maps[^>]*>[^<]*</iframe>\s*</figure>',
        '', raw, flags=re.DOTALL|re.IGNORECASE
    )
    raw = re.sub(
        r'<iframe[^>]*google[.]com/maps[^>]*>[^<]*</iframe>',
        '', raw, flags=re.DOTALL|re.IGNORECASE
    )

    # ── Paragrafları böl ──────────────────────────────────────────────────
    # P1+P2 → giriş referansı (Claude)
    # P3+P4 → kişisel bakış referansı (GPT)
    # P5+   → gövde (GPT)
    p_all = list(re.finditer(r'<p>.*?</p>', raw, re.DOTALL))
    if len(p_all) >= 4:
        intro_raw    = raw[:p_all[1].end()].strip()
        kisisel_raw  = raw[p_all[2].start():p_all[3].end()].strip()
        body_raw     = raw[p_all[3].end():].strip()
    elif len(p_all) >= 2:
        intro_raw    = raw[:p_all[1].end()].strip()
        kisisel_raw  = ""
        body_raw     = raw[p_all[1].end():].strip()
    else:
        intro_raw    = raw[:600]
        kisisel_raw  = ""
        body_raw     = raw[600:]

    # ── Gutenberg <p> sarıcı ─────────────────────────────────────────────
    def wrap_paras(html):
        parts = []
        for p in re.findall(r'<p>.*?</p>', html, re.DOTALL):
            parts.append(f"<!-- wp:paragraph -->\n{p}\n<!-- /wp:paragraph -->")
        if not parts:
            return f"<!-- wp:paragraph -->\n<p>{html.strip()}</p>\n<!-- /wp:paragraph -->"
        return "\n\n".join(parts)

    # ══════════════════════════════════════════════════════════════════════
    # ADIM 1 — Claude: 2 paragraf giriş (Anlatı Mimarisi sesi)
    # ══════════════════════════════════════════════════════════════════════
    print("   🔵 ADIM 1: Giriş (Claude — Anlatı Mimarisi)...")
    giris_prompt = (
        "SEN: yoldaolmak.com yazari Kemal Kaya.\n"
        "GOREV: '" + title + "' icin ilk 2 giris paragrafi.\n\n"
        + GIRIS_TRAINING
        + "\nORIJINAL (referans al, tamamen yeniden yaz):\n"
        + intro_raw
        + "\n\nCIKTI: Sadece 2 <p>...</p>. Fazlasi degil."
    )

    giris_raw = ask_claude_only(giris_prompt, max_tokens=1500)    # Claude (WHERE ile aynı limit)
    giris_raw = clean_html(giris_raw)
    giris_raw = fix_md_bold_italic(giris_raw)
    giris_raw = auto_fix_gpt_output(giris_raw)
    kalip = check_giris_kalip(giris_raw, title)
    if kalip:
        import random as _rnd
        _dest_k = title.split("Gezi")[0].split("Nerede")[0].strip()
        _tip = _rnd.choice([
            "İlk fark ettiğim şey " + _dest_k + " değildi. Başka bir şey vurdu:",
            _dest_k + " için bir hafta önceden beklentim şuydu. Yanıldım.",
            "Sabah 7'de " + _dest_k + "'te kimse yok. O boşlukta şehri gördüm:"
        ])
        _retry_prompt = (
            giris_prompt
            + "\n\n⚠️ RETRY — önceki deneme kalıp kullandığı için reddedildi."
            + "\nZORUNLU: İlk cümle şu yapıyla başlamalı (sözcükleri değiştir):"
            + "\n→ " + _tip
            + "\nKALIP YASAK: herkes/haklıydılar/beklediğim gibi değildi/zaman yolculuğu"
        )
        print(f"      ⚠️  Kalıp tespit ({kalip[0]}) → farklı açılış zorlanıyor...")
        giris_raw = ask_claude_only(_retry_prompt, max_tokens=1500)    # Claude
        giris_raw = clean_html(giris_raw)
        giris_raw = fix_md_bold_italic(giris_raw)
    giris_out = wrap_paras(giris_raw)
    print(f"      ✅ Giriş: {giris_out.count('<!-- wp:paragraph -->')} paragraf")

    # ══════════════════════════════════════════════════════════════════════
    # ADIM 2 — CLAUDE: 2 paragraf kişisel bakış (özgün ses, where ile tutarlı)
    # ══════════════════════════════════════════════════════════════════════
    print("   🔵 ADIM 2: Kişisel bakış (Claude — özgün ses)...")
    kisisel_prompt = f"""SEN: yoldaolmak.com yazari Kemal Kaya.
GOREV: "{title}" icin giris sonrasi 2 paragraf.

{GIRIS_SONRASI_TRAINING}

ORIJINAL REFERANS:
{kisisel_raw or body_raw[:400]}

CIKTI: Sadece 2 <p>...</p>. Gutenberg etiketi ekleme."""

    kisisel_out_raw = ask_claude_only(kisisel_prompt, max_tokens=800)  # Token optimizasyonu
    kisisel_out_raw = clean_html(kisisel_out_raw)
    kisisel_out_raw = fix_md_bold_italic(kisisel_out_raw)
    kisisel_out_raw = auto_fix_gpt_output(kisisel_out_raw)
    kisisel_out = wrap_paras(kisisel_out_raw)
    print(f"      ✅ Kişisel bakış: {kisisel_out.count('<!-- wp:paragraph -->')} paragraf")

    # ══════════════════════════════════════════════════════════════════════
    # ADIM 3 — GPT: Gövde (H2/H3 bölümler, tam Gutenberg)
    # ══════════════════════════════════════════════════════════════════════
    print("   🟢 ADIM 3: Gövde (GPT — H2/H3 bölümleri)...")
    orig_h2s = re.findall(r'<h2[^>]*>(.*?)</h2>', raw, re.DOTALL)
    h2_texts = [re.sub(r'<[^>]+>', '', h).strip() for h in orig_h2s]
    h2_list  = "\n".join("  • " + h for h in h2_texts)
    h2_hint  = f"\nORİJİNAL H2 BAŞLIKLARI (koru/iyileştir):\n{h2_list}" if h2_list else ""

    # "Gezilecek yerler" H2 var mı? VEYA numaralı yer listesi var mı? → özel training ekle
    has_gezilecek = (
        any("gezilecek" in h.lower() or "gezip" in h.lower() or "görülecek" in h.lower()
            for h in h2_texts)
        or bool(re.search(r'^\s*[1-9]\.\s+[A-ZÇĞİÖŞÜa-zçğışöüI]', body_raw, re.MULTILINE))
    )
    gezilecek_extra = (
        "\n\n" + GEZILECEK_TRAINING
        if has_gezilecek else ""
    )

    # ── Destinasyon + Türkiye kontrolü ─────────────────────────────────
    _draft_dest = extract_dest(title)
    _draft_flag = get_flag(_draft_dest)
    _is_turkey  = (_draft_flag == '')
    _turkey_directive = ""
    if _is_turkey:
        _turkey_directive = (
            "\n\n🇹🇷 TÜRKİYE DESTİNASYONU — KESİNLİKLE YASAK:\n"
            "- Saat dilimi bilgisi VERME (UTC+3 vb.)\n"
            "- Vize bilgisi VERME\n"
            "- Pasaport kontrolü bilgisi VERME\n"
        )

    # Düz f-string — .format() YOK, {body_raw} ve {h2_hint} direkt
    body_prompt_final = f"""{DRAFT_TRAINING}
{GOVDE_MAD_TRAINING}{gezilecek_extra}{_turkey_directive}

GÖREV: "{title}" — giriş paragrafları (P1-P2 ve P3-P4) YAZILDI, TEKRAR YAZMA.
GPT'nin görevi: giriş sonrasındaki TÜM bölümleri (H2, H3, paragraflar) yeniden yaz ve geliştir.{h2_hint}

ORİJİNAL GÖVDE (yeniden yaz, geliştir):
{body_raw}

ZORUNLU FORMAT:

H2 (her H2 önünde separator):
  <!-- wp:separator -->
  <hr class="wp-block-separator has-alpha-channel-opacity"/>
  <!-- /wp:separator -->
  <!-- wp:heading {{"level":2}} -->
  <h2 class="wp-block-heading"><strong>✈️ [Başlık]</strong></h2>
  <!-- /wp:heading -->

H3 Standart:
  <!-- wp:heading {{"level":3}} -->
  <h3 class="wp-block-heading"><strong>[Alt Başlık]</strong></h3>
  <!-- /wp:heading -->

H3 Gezilecek Yer (ZORUNLU — numara ile başlayan her yer):
  <!-- wp:heading {{"level":3}} -->
  <h3 class="wp-block-heading"><strong>N. Yer Adı — Kısa tematik/mimari tanım</strong></h3>
  <!-- /wp:heading -->

Paragraf:
  <!-- wp:paragraph -->
  <p>İçerik.</p>
  <!-- /wp:paragraph -->

YASAK: ## ### markdown | <ul><li> liste | metin içi tire "—" | yasak sıfatlar

NASIL GİDİLİR BÖLÜMÜ İÇİN ÖZEL KURALLAR (varsa):
- Sadece gerçekten var olan ulaşım seçeneklerini yaz
- Tren yoksa "tren bağlantısı yoktur" diye de yazma, o başlığı hiç açma
- Feribot yoksa aynı şekilde
- Koordinat, enlem, boylam hiçbir şekilde ekleme
- Her ulaşım türü için 1 paragraf, pratik bilgi, gerçek şirket/havalimanı adları

ÇIKTI: SADECE Gutenberg HTML. Açıklama ekleme."""

    body_raw_gpt = safe_ai(body_prompt_final, body_raw, max_tokens=8000,
                           min_ratio=0.65, min_chars=len(body_raw)//2)
    body_raw_gpt = auto_fix_gpt_output(body_raw_gpt)
    body_raw_gpt = fix_md_bold_italic(body_raw_gpt)
    body_out     = wrap_gutenberg(body_raw_gpt)

    # Validasyon
    h2_c  = body_out.count('<!-- wp:heading {"level":2}')
    h3_c  = body_out.count('<!-- wp:heading {"level":3}')
    sep_c = body_out.count('<!-- wp:separator')
    md_l  = len(re.findall(r'^#{1,3} ', body_out, re.MULTILINE))
    _body_no_h3 = re.sub(r'<h3[^>]*>.*?</h3>', '', body_out,
                         flags=re.DOTALL | re.IGNORECASE)
    tire = _body_no_h3.count('\u2014') + _body_no_h3.count('\u2013')
    print(f"      ✅ Gövde: {len(body_out):,} char  H2:{h2_c} H3:{h3_c} Sep:{sep_c}")
    if md_l:  print(f"      ⚠️  Markdown kalıntı: {md_l}")
    if tire:  print(f"      ⚠️  Tire kalıntı: {tire}")
    if sep_c < h2_c: print(f"      ⚠️  Separator eksik: {h2_c} H2, {sep_c} sep")

    # ── BİRLEŞTİR ────────────────────────────────────────────────────────
    result = giris_out + "\n\n" + kisisel_out + "\n\n" + body_out
    result = clean_html(result)
    result = dedup_separators(result)

    # ── M3: Google Maps iframe → Rich Maps Box ────────────────────────
    _has_maps_result = bool(re.search(r'google[.]com/maps', result, re.IGNORECASE))
    _maps_injected   = False
    if _has_orig_maps or _has_maps_result:
        try:
            _rich_map = get_rich_maps_box(_draft_dest)
            # Gutenberg wp:html bloğu içindeki iframe'i değiştir
            result, _n1 = re.subn(
                r'<!-- wp:html -->.*?google[.]com/maps.*?<!-- /wp:html -->',
                _rich_map, result, flags=re.DOTALL|re.IGNORECASE
            )
            # Direkt iframe
            result, _n2 = re.subn(
                r'<iframe[^>]*google[.]com/maps[^>]*>.*?</iframe>',
                _rich_map, result, flags=re.DOTALL|re.IGNORECASE
            )
            _maps_injected = (_n1 + _n2) > 0
            if not _maps_injected:
                # Fallback 1: Nerede/Konum/Harita H2'sinden sonra
                _nerede_m = re.search(
                    r'(<!-- wp:heading \{"level":2\} -->\s*<h2[^>]*>[^<]*(?:[Nn]erede|[Kk]onum|[Hh]arita)[^<]*</h2>\s*<!-- /wp:heading -->)',
                    result, re.DOTALL
                )
                if _nerede_m:
                    _ins = _nerede_m.end()
                    result = result[:_ins] + "\n\n" + _rich_map + result[_ins:]
                    _maps_injected = True
                else:
                    # Fallback 2: Nasıl Gidilir H2'sinden sonra
                    _gidilir_m = re.search(
                        r'(<!-- wp:heading \{"level":2\} -->\s*<h2[^>]*>[^<]*(?:[Nn]asıl\s*[Gg]idilir|[Uu]laşım)[^<]*</h2>\s*<!-- /wp:heading -->)',
                        result, re.DOTALL
                    )
                    if _gidilir_m:
                        _ins = _gidilir_m.end()
                        result = result[:_ins] + "\n\n" + _rich_map + result[_ins:]
                        _maps_injected = True
                    else:
                        # Fallback 3: İlk separator'dan sonra (gövde başı)
                        _sep_m = re.search(r'(<!-- wp:separator -->.*?<!-- /wp:separator -->)',
                                          result, re.DOTALL)
                        if _sep_m:
                            _ins = _sep_m.end()
                            result = result[:_ins] + "\n\n" + _rich_map + result[_ins:]
                            _maps_injected = True
            print(f"   🗺️  M3: Rich Maps Box {'enjekte edildi' if _maps_injected else 'yerleştirme başarısız'}")
        except Exception as _me:
            print(f"   ⚠️  M3: Maps box hatası: {_me}")

    # ── M5: H başlıklarını Türkçe title case'e çevir ─────────────────
    result = capitalize_h_titles(result)
    print(f"   🔤 M5: H başlıkları capitalize edildi")

    # ── İlk H2'ye bayrak ─────────────────────────────────────────────
    result = add_flag_to_first_h2(result, _draft_flag)
    result = enforce_h2_emojis(result, _draft_flag)     # S3+S4: Tüm H2 emoji kuralları

    # ── Banned check ──────────────────────────────────────────────────
    issues = check_banned(result)
    if issues:
        print(f"\n   ⚠️  BANNED: {', '.join(issues[:5])}")

    # ── Schema + FAQ ──────────────────────────────────────────────────
    try:
        schema_faq_d = build_faq_schema(
            _draft_dest, "draft",
            headline=title,
            today=today
        )
        result = result + "\n\n" + schema_faq_d
        print("   📋 Schema + FAQ eklendi (DRAFT mod)")
    except Exception as _se:
        print(f"   ⚠️  Schema hatasi: {_se}")

    # ════════════════════════════════════════════════════════════════════
    # ADIM 8c: YOAST META (DRAFT mod)
    # ════════════════════════════════════════════════════════════════════
    yoast_title_d, yoast_desc_d = build_yoast_meta(_draft_dest)
    focuskw_d   = f"{_draft_dest} nerede nasıl gidilir"
    # G1: Bayrak + G2: OK! suffix — clawdbot.py ikinci kayıt YOK
    _title_flag  = get_flag(_draft_dest)
    new_title_d  = title
    # Bayrak henüz başlıkta yoksa ekle
    if _title_flag and _title_flag not in new_title_d:
        new_title_d = new_title_d + " " + _title_flag
    # Aynı başlıklı eski draftlardan ayırt etmek için OK! suffix
    if not new_title_d.endswith(" OK!"):
        new_title_d = new_title_d + " OK!"
    print(f"   🔍 ADIM 8c: Yoast meta hazır ({len(yoast_desc_d)} kar.)")
    print(f"      📝 H1:    {new_title_d}")
    print(f"      📖 Meta:  {yoast_desc_d[:65]}...")
    print(f"      🔑 kw:    {focuskw_d}")

    # ════════════════════════════════════════════════════════════════════
    # ADIM 10: YEREL KAYDET + WP YENİ DRAFT POST OLUŞTUR
    # Orijinal post (pid) değiştirilmez.
    # Aynı kategoriye yeni status=draft post açılır.
    # ════════════════════════════════════════════════════════════════════
    os.makedirs(cat_slug, exist_ok=True)
    local_file = f"{cat_slug}/{pid}-{today}-draft.html"
    with open(local_file, 'w', encoding='utf-8') as _f:
        _f.write(result)
    print(f"   💾 Yerel: {local_file}")

    _new_draft_id = None
    print(f"   📤 ADIM 10: WordPress'e yeni DRAFT post yazılıyor (kategori: {cat_slug})...")
    try:
        _resp = save_as_draft(
            pid,               # sadece kategori referansı için
            new_title_d,
            result,
            categories=orig_cats or None,
            yoast_title=yoast_title_d,
            yoast_desc=yoast_desc_d,
            yoast_focuskw=focuskw_d,
        )
        _new_draft_id = _resp.get('id')
        _draft_link   = _resp.get('link', '')
        print(f"      ✅ Yeni draft oluşturuldu — ID: {_new_draft_id}")
        print(f"      📂 Kategori: {cat_slug}  (orijinal ID {pid} dokunulmadı)")
        print(f"      🔗 {_draft_link}")
        # Ayrı PATCH: Yoast meta alanları yeni draft'a yazılsın
        if _new_draft_id:
            update_yoast_meta(_new_draft_id, yoast_title_d, yoast_desc_d, focuskw_d)
    except Exception as _we:
        print(f"      ⚠️  WordPress hatası: {_we}")

    # ════════════════════════════════════════════════════════════════════
    # M6: KONTROL — 6 madde validation
    # ════════════════════════════════════════════════════════════════════
    _renkli_ok = (
        'background-color' not in result.split('<script')[0] and
        'has-background'   not in result.split('<script')[0]
    )
    _nasil_ok  = bool(re.search(r'nasil\s*gidilir|nasıl\s*gidilir', result, re.I))
    _h2_lower  = bool(re.search(r'<h2[^>]*>\s*(?:<[^>]+>)*\s*[a-zçğışöü]{3,}', result, re.DOTALL))
    _h3_lower  = bool(re.search(r'<h3[^>]*>\s*(?:<[^>]+>)*\s*[a-zçğışöü]{3,}', result, re.DOTALL))

    _checks = [
        ("M1 Yeni draft oluşturuldu",      _new_draft_id is not None),
        ("M1 Kategori orijinal ile aynı",  bool(orig_cats)),
        ("M2 Giriş ≥2 paragraf",           giris_out.count('<!-- wp:paragraph -->') >= 2),
        ("M2 Giriş Claude yazdı",          True),
        ("M3 Maps box işlendi",            not _has_orig_maps or _maps_injected),
        ("M4 Renkli box yok",              _renkli_ok),
        ("M4 Nasıl Gidilir var",           _nasil_ok),
        ("M5 H2 capitalize",               not _h2_lower),
        ("M5 H3 capitalize",               not _h3_lower),
        ("Yoast desc var",                 len(yoast_desc_d) >= 80),
        ("Schema/FAQ var",                 'FAQPage' in result or 'yoa-faq' in result),
    ]
    _all_ok = all(v for _, v in _checks)
    total   = len(result)
    g_blok  = result.count('<!-- wp:')

    print(f"\n   {'✅' if _all_ok else '⚠️ '} Draft tamam: {total:,} char | {g_blok} blok | {cat_slug}/")
    print(f"   📋 M6 KONTROL ({sum(v for _,v in _checks)}/{len(_checks)}):")
    for lbl, ok in _checks:
        print(f"      {'✅' if ok else '❌'} {lbl}")
    return result



# ══════════════════════════════════════════════════════════════════════════════
# GUIDE MOD — Gezi Rehberi Formatı
# ══════════════════════════════════════════════════════════════════════════════
def wrap_paras_inline(html):
    """Basit <p> taglarını Gutenberg bloklarına sar"""
    parts = []
    for p in re.findall(r'<p[^>]*>.*?</p>', html, re.DOTALL):
        parts.append(f"<!-- wp:paragraph -->\n{p}\n<!-- /wp:paragraph -->")
    if not parts:
        return f"<!-- wp:paragraph -->\n<p>{html.strip()}</p>\n<!-- /wp:paragraph -->"
    return "\n\n".join(parts)


# GUIDE için özel Yoast meta
def build_yoast_meta_guide(dest: str) -> tuple[str, str]:
    """GUIDE mod için Yoast meta title + description"""
    yoast_title = f"{dest} Gezi Rehberi: Gezilecek Yerler, Konaklama, Pratik Bilgiler"
    yoast_desc = (
        f"{dest} gezi rehberi: mutlaka görülmesi gereken yerler, ne yenir, "
        f"nerede kalınır, alışveriş önerileri ve pratik bilgiler."
    )
    # 158 karakteri geçmesin
    if len(yoast_desc) > 158:
        yoast_desc = yoast_desc[:155] + '...'
    return yoast_title, yoast_desc


def revise_guide_post(post):
    """
    GUIDE modu — Destinasyon Gezi Rehberi formatı (YENİ):
    - H1: {Destinasyon} Gezi Rehberi {🇹🇷}
    - Giriş 2§ (Claude)
    - İlk fotoğraf
    - Kişisel Bakış 2§ (Claude)
    - H2: Gezi Rehberi (GPT, 7-8 paragraf)
    - H2: Gezilecek Yerler (GPT, paragraf + H3 listesi)
    - H2: Yeme İçme Rehberi (GPT)
    - H2: Konaklama Önerileri (GPT)
    - H2: Alışveriş Rehberi (GPT)
    - H2: Pratik Bilgiler (GPT)
    - Kapanış 2§ (GPT)
    - FAQ + Schema (7 soru, GPT)
    """
    pid     = post['id']
    title   = post['title']['rendered']
    content = post['content']['rendered']
    today   = datetime.now().strftime('%Y-%m-%d')
    images  = extract_all_images(content)

    dest = extract_dest(title)
    flag = get_flag(dest)
    _is_turkey = (flag == '')

    # Orijinal kategorileri al
    try:
        orig_cats = get_post_categories(pid)
        cat_slug  = get_category_path(orig_cats[0]) if orig_cats else 'draft'
    except Exception:
        orig_cats, cat_slug = [], 'draft'

    print(f"\n📖 GUIDE MODE: {dest} {flag}")
    print(f"   📦 Post ID: {pid}")
    print(f"   🖼️  Fotoğraflar: {len(images)}\n")

    # ══════════════════════════════════════════════════════════════════════
    # ADIM 1: GİRİŞ 2 PARAGRAF (Claude)
    # ══════════════════════════════════════════════════════════════════════
    print("   🔵 ADIM 1: Giriş paragrafları (Claude)...")
    giris_prompt = f"""{GIRIS_TRAINING}

SEN: yoldaolmak.com yazarı Kemal Kaya
GÖREV: {dest} Gezi Rehberi için giriş 2 paragrafı.

ÇIKTI: 2 adet <p>...</p>
"""
    giris_raw = ask_ai(giris_prompt, max_tokens=1500)  # Claude
    giris_raw = clean_html(giris_raw)
    giris_raw = fix_md_bold_italic(giris_raw)
    giris_raw = auto_fix_gpt_output(giris_raw)
    giris_raw = wrap_paras_inline(giris_raw)
    print(f"      ✅ Giriş: {giris_raw.count('<p>')} paragraf")

    # ══════════════════════════════════════════════════════════════════════
    # ADIM 2: İLK FOTOĞRAF
    # ══════════════════════════════════════════════════════════════════════
    first_img_html = ""
    if images:
        first_img_html = img_wrapper(
            images[0]['src'],
            images[0]['alt'] or f"{dest} şehir manzarası"
        )
        print(f"   🖼️  ADIM 2: İlk fotoğraf eklendi")
    else:
        print(f"   ⚠️  ADIM 2: Fotoğraf bulunamadı")

    # ══════════════════════════════════════════════════════════════════════
    # ADIM 3: KİŞİSEL BAKIŞ 2 PARAGRAF (Claude)
    # ══════════════════════════════════════════════════════════════════════
    print("   🔵 ADIM 3: Kişisel Bakış (Claude)...")
    kisisel_prompt = f"""{GIRIS_SONRASI_TRAINING}

{dest} hakkında kişisel bakış ve yorum: olumlu + olumsuz + özet.

ÇIKTI: 2 adet <p>...</p>
"""
    kisisel_raw = ask_ai(kisisel_prompt, max_tokens=800)  # Claude
    kisisel_raw = clean_html(kisisel_raw)
    kisisel_raw = auto_fix_gpt_output(kisisel_raw)
    kisisel_raw = wrap_paras_inline(kisisel_raw)
    print(f"      ✅ Kişisel Bakış: {kisisel_raw.count('<p>')} paragraf")

    SEP = '<!-- wp:separator -->\n<hr class="wp-block-separator has-alpha-channel-opacity"/>\n<!-- /wp:separator -->'

    # ══════════════════════════════════════════════════════════════════════
    # ADIM 5: H2 "{Destinasyon} Gezi Rehberi" (GPT, 7-8 paragraf)
    # ══════════════════════════════════════════════════════════════════════
    print("   🟢 ADIM 5: Gezi Rehberi bölümü (GPT)...")
    
    _turkey_directive = ""
    if _is_turkey:
        _turkey_directive = (
            "\n🚫 TÜRKİYE DESTİNASYONU:\n"
            "   ❌ Saat dilimi bilgisi VERME\n"
            "   ❌ Vize bilgisi VERME\n"
            "   ❌ Pasaport kontrolü VERME\n"
            "   ❌ Saat farkı sorusu SORMA\n"
        )
    
    gezi_rehberi_prompt = f"""{_turkey_directive}
{DIL_KURALLARI}

GÖREV: {dest} Gezi Rehberi — "Nasıl Bir Yer" benzeri, ama daha kapsamlı

BAŞLIK: <h2 class="wp-block-heading"><strong>{dest} Gezi Rehberi {flag}</strong></h2>

İÇERİK (7-8 paragraf):
1. Coğrafi Lokasyon: Nerede, hangi ülke/bölge, nehir/dağ/deniz ilişkisi
2. Tarihi Önem: Neden önemliydi? Stratejik konum, ticaret yolları, medeniyetler için değeri, başkentlik
   (Tarihi hikaye değil — kim kimi öldürdü anlatma. Tarihin önemini anlat: Neden stratejikti?)
3. İnsanı: Yerel halk nasıl? Misafirperver mi, ilgisiz mi? Somut gözlem.
4. Kültür Özellikleri: Mimari, sanat, müzik, festival, yerel yaşam tarzı
5. İlk Gezginler İçin: Hafızada tablo oluşturacak ülke profili, ilgi çekici bilgiler
6. Destinasyona Neden Gidilmeli: Soft mesaj, çekici yanları (abartısız)
7. Vize/Saat Farkı: {f"Türkiye ile saat farkı, vize durumu (kısa)" if not _is_turkey else "Türkiye içi, saat farkı/vize bilgisi VERME"}

ÇIKTI: H2 + 7-8 paragraf (HTML)
"""
    gezi_rehberi_raw = ask_gpt_only(gezi_rehberi_prompt, max_tokens=2500)
    gezi_rehberi_raw = clean_html(gezi_rehberi_raw)
    gezi_rehberi_raw = auto_fix_gpt_output(gezi_rehberi_raw)
    gezi_rehberi_out = wrap_gutenberg(gezi_rehberi_raw)
    print(f"      ✅ Gezi Rehberi hazır")

    # ══════════════════════════════════════════════════════════════════════
    # ADIM 7: H2 "GEZİLECEK YERLER" (Paragraf + H3 listesi)
    # ══════════════════════════════════════════════════════════════════════
    print("   📸 ADIM 7: Gezilecek Yerler...")
    gezilecek_prompt = f"""{DIL_KURALLARI}

GÖREV: {dest} için "GEZİLECEK YERLER" bölümü

BAŞLIK: <h2 class="wp-block-heading"><strong>{dest} Gezilecek Yerler 📸</strong></h2>

━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
BÖLÜM 1 — GEZİ TAVSİYELERİ (3-5 paragraf)
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
Destinasyon nasıl gezilir? Pratik ipuçları:

PARAGRAF 1: Genel gezi stratejisi
- Şehir merkezi yürüyerek gezilir mi?
- Araç kiralama gerekli mi?
- Hangi bölgelerden başlamalı?

PARAGRAF 2: Kaç gün yeterli?
- Minimum/ideal/uzun süre ayrımı
- Her gün için ne kadar zaman

PARAGRAF 3: Ulaşım ipuçları
- Toplu taşıma bileti/kartı
- Taksi/Uber durumu
- Tur seçenekleri (sightseeing, hop-on-hop-off)

PARAGRAF 4-5: Zamanlama ve bilet tavsiyeleri
- En iyi gezi saatleri (sabah/akşam)
- Hangi yerler için önceden bilet
- Kaçınılması gereken zamanlar (tatil, pazar günü vb.)

ÖNEMLİ: Mutlaka görülmesi gereken yerleri sadece SAY, detaylandırma (H3'te anlatılacak)

━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
BÖLÜM 2 — H3 LİSTESİ (5-7 yer, her biri 2-3 paragraf)
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

H3 FORMAT (ZORUNLU):
### {{Sıra}}. {{Yer Adı}} - {{Kısa tanıtım}}

Örnek: ### 1. Karl Köprüsü - Prag'ın en ünlü simgesi

HER YER İÇİN 2-3 PARAGRAF (ZORUNLU):

PARAGRAF 1 (Karakter ve Özellikler):
Şu soruları cümle içinde yanıtla:
- Nasıl bir yer? (atmosfer, doku, karakter)
- Ne özellikleri var? (mimari, tarih, doğa, ilginç detaylar)
Örnek: "**Karl Köprüsü**, Prag'ın Vltava Nehri üzerindeki 14. yüzyıldan kalma 
taş köprüsü. 516 metre uzunluğunda, her iki tarafında 30 aziz heykeli var. 
Sabah erken saatlerde tenha, öğleden sonra turist kalabalığıyla doluyor."

PARAGRAF 2 (Neden Görülmeli + Ne Yapılır):
- Neden görülmeli? (öne çıkan yön, eşsiz özellik, deneyim vaadi)
- Ne yapılır? (içinde gezilecek noktalar, aktiviteler)
Örnek: "Köprü Prag'ın en ikonik noktası. Eski Şehir ile Prag Kalesi'ni bağlıyor, 
yürürken şehrin panoraması görünüyor. Heykellere yakından bakılmalı, özellikle 
Aziz Jan Nepomuk heykeli (sol tarafta) turistler için şans getiriyor deniliyor."

PARAGRAF 3 (Pratik Bilgiler — cümle içinde, liste DEĞİL):
- Giriş ücreti (varsa)
- Açılış saatleri
- Gezmek için önerilen süre
- Ulaşım (nereden, nasıl)
Örnek: "Köprü ücretsiz, 24 saat açık. Sabah 7-8 arası gitmek ideal, kalabalık 
olmuyor. Yürüyerek geçmek 8-10 dakika. Eski Şehir Meydanı'ndan yürüyerek 
5 dakika mesafede. Akşam aydınlatması güzel, gün batımından sonra da gezebilirsiniz."

━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

HER H3 ARASINA SEPARATOR:
<!-- wp:separator -->
<hr class="wp-block-separator has-alpha-channel-opacity"/>
<!-- /wp:separator -->

ÇIKTI: H2 + giriş paragrafları + H3'ler + separator'lar (HTML)
"""
    gezilecek_raw = ask_gpt_only(gezilecek_prompt, max_tokens=6000)
    gezilecek_raw = clean_html(gezilecek_raw)
    gezilecek_raw = auto_fix_gpt_output(gezilecek_raw)
    gezilecek_out = wrap_gutenberg(gezilecek_raw)
    print(f"      ✅ Gezilecek Yerler hazır")

    # ══════════════════════════════════════════════════════════════════════
    # ADIM 8: H2 "YEME İÇME REHBERİ"
    # ══════════════════════════════════════════════════════════════════════
    print("   🍽️  ADIM 8: Yeme İçme Rehberi...")
    yeme_icme_prompt = f"""{DIL_KURALLARI}

GÖREV: {dest} için "YEME İÇME REHBERİ" bölümü

BAŞLIK: <h2 class="wp-block-heading"><strong>{dest} Yeme İçme Rehberi 🍽️</strong></h2>

İÇERİK (4-5 paragraf):
- Yerel mutfak karakteri, meşhur yemekler (somut isimler)
- Sokak lezzetleri (nerede, ne kadar)
- Restoran önerileri: bütçe/orta/lüks (isim ver, konum belirt)
- Ne nerede yenir? (bölge bazında)

ÇIKTI: H2 + paragraflar (HTML)
"""
    yeme_icme_raw = ask_gpt_only(yeme_icme_prompt, max_tokens=1800)
    yeme_icme_raw = clean_html(yeme_icme_raw)
    yeme_icme_raw = auto_fix_gpt_output(yeme_icme_raw)
    yeme_icme_out = wrap_gutenberg(yeme_icme_raw)
    print(f"      ✅ Yeme İçme hazır")

    # ══════════════════════════════════════════════════════════════════════
    # ADIM 9: H2 "KONAKLAMA ÖNERİLERİ"
    # ══════════════════════════════════════════════════════════════════════
    print("   🏨 ADIM 9: Konaklama Önerileri...")
    konaklama_prompt = f"""{DIL_KURALLARI}

GÖREV: {dest} için "KONAKLAMA ÖNERİLERİ" bölümü

BAŞLIK: <h2 class="wp-block-heading"><strong>{dest} Konaklama Önerileri 🏨</strong></h2>

İÇERİK (3-4 paragraf):
- Hangi bölgede kalınmalı? (şehir merkezi / sahil / sakin bölge)
- Bütçe seçenekleri: Hostel, apart, otel (fiyat aralığı ver)
- Önerilen oteller: İsim ver, kısa açıkla, hangi bölgede

ÇIKTI: H2 + paragraflar (HTML)
"""
    konaklama_raw = ask_gpt_only(konaklama_prompt, max_tokens=1400)
    konaklama_raw = clean_html(konaklama_raw)
    konaklama_raw = auto_fix_gpt_output(konaklama_raw)
    konaklama_out = wrap_gutenberg(konaklama_raw)
    print(f"      ✅ Konaklama hazır")

    # ══════════════════════════════════════════════════════════════════════
    # ADIM 10: H2 "ALIŞVERİŞ REHBERİ"
    # ══════════════════════════════════════════════════════════════════════
    print("   🛍️  ADIM 10: Alışveriş Rehberi...")
    alisveris_prompt = f"""{DIL_KURALLARI}

GÖREV: {dest} için "ALIŞVERİŞ REHBERİ" bölümü

BAŞLIK: <h2 class="wp-block-heading"><strong>{dest} Alışveriş Rehberi 🛍️</strong></h2>

İÇERİK (3 paragraf):
- Ne alınır? (yerel ürünler, hediyelikler — somut isimler)
- Nereden alınır? (çarşı, pazar, AVM — isim ver)
- Pazarlık yapılır mı? Fiyat aralıkları

ÇIKTI: H2 + paragraflar (HTML)
"""
    alisveris_raw = ask_gpt_only(alisveris_prompt, max_tokens=1200)
    alisveris_raw = clean_html(alisveris_raw)
    alisveris_raw = auto_fix_gpt_output(alisveris_raw)
    alisveris_out = wrap_gutenberg(alisveris_raw)
    print(f"      ✅ Alışveriş hazır")

    # ══════════════════════════════════════════════════════════════════════
    # ADIM 11: H2 "PRATİK BİLGİLER"
    # ══════════════════════════════════════════════════════════════════════
    print("   💡 ADIM 11: Pratik Bilgiler...")
    
    if _is_turkey:
        _pratik_icerik = (
            "- En iyi seyahat zamanı (ay bazında, mevsim özellikleri)\n"
            "- Güvenlik durumu (gerçekçi, abartısız)\n"
            "- Elektrik voltaj, priz tipi (varsa özel durum)\n"
            "- Acil numaralar (polis, ambulans, itfaiye)\n"
            "- 5-7 kısa ipucu (her biri 1 paragraf, pratik bilgi)"
        )
    else:
        _pratik_icerik = (
            "- En iyi seyahat zamanı (ay bazında, mevsim özellikleri)\n"
            "- Güvenlik durumu (gerçekçi, abartısız)\n"
            "- Türk vatandaşları için özel notlar (vize, giriş şartları)\n"
            "- Elektrik voltaj, priz tipi\n"
            "- Acil numaralar (polis, ambulans, itfaiye)\n"
            "- 5-7 kısa ipucu (her biri 1 paragraf, pratik bilgi)"
        )
    
    pratik_prompt = f"""{DIL_KURALLARI}

GÖREV: {dest} için "PRATİK BİLGİLER" bölümü

BAŞLIK: <h2 class="wp-block-heading"><strong>{dest} Pratik Bilgiler ve İpuçları 💡</strong></h2>

İÇERİK (6-8 paragraf):
{_pratik_icerik}

{_turkey_directive}

ÇIKTI: H2 + paragraflar (HTML)
"""
    pratik_raw = ask_gpt_only(pratik_prompt, max_tokens=1800)
    pratik_raw = clean_html(pratik_raw)
    pratik_raw = auto_fix_gpt_output(pratik_raw)
    pratik_out = wrap_gutenberg(pratik_raw)
    print(f"      ✅ Pratik Bilgiler hazır")

    # ══════════════════════════════════════════════════════════════════════
    # ADIM 12: KAPANIŞ 2 PARAGRAF (GPT)
    # ══════════════════════════════════════════════════════════════════════
    print("   📝 ADIM 12: Kapanış...")
    alisveris_prompt = f"""GÖREV: {dest} için "ALIŞVERİŞ REHBERİ" bölümü

BAŞLIK: <h2 class="wp-block-heading"><strong>{dest} Alışveriş Rehberi 🛍️</strong></h2>

İÇERİK:
- Ne alınır? (yerel ürünler, hediyelikler)
- Nereden alınır? (çarşı, pazar, AVM)
- Pazarlık var mı?

BOLD: Ürün adları, çarşı/pazar adları
ÇIKTI: H2 + paragraflar (HTML)
"""
    alisveris_raw = ask_gpt_only(alisveris_prompt, max_tokens=1000)
    alisveris_raw = clean_html(alisveris_raw)
    alisveris_raw = auto_fix_gpt_output(alisveris_raw)
    alisveris_out = wrap_gutenberg(alisveris_raw)
    print(f"      ✅ Alışveriş hazır")

    # ══════════════════════════════════════════════════════════════════════
    print(f"      ✅ Kapanış hazır")

    # ══════════════════════════════════════════════════════════════════════
    # ADIM 13: FAQ + SCHEMA (7 soru)
    # ══════════════════════════════════════════════════════════════════════
    print("   ❓ ADIM 13: FAQ + Schema...")
    yoast_title, yoast_desc = build_yoast_meta_guide(dest)
    faq_schema_html = build_faq_schema(dest, "guide", yoast_title, yoast_desc, today)
    print(f"      ✅ FAQ + Schema hazır")

    # ══════════════════════════════════════════════════════════════════════
    # BİRLEŞTİR + H1 + EMOJI FİX
    # ══════════════════════════════════════════════════════════════════════
    combined = (
        giris_raw + "\n\n"
        + first_img_html + "\n\n"
        + kisisel_raw + "\n\n"
        + SEP + "\n\n"
        + gezi_rehberi_out + "\n\n"
        + SEP + "\n\n"
        + gezilecek_out + "\n\n"
        + yeme_icme_out + "\n\n"
        + konaklama_out + "\n\n"
        + alisveris_out + "\n\n"
        + pratik_out + "\n\n"
        + kapanis_raw + "\n\n"
        + faq_schema_html
    )

    combined = clean_html(combined)
    combined = dedup_separators(combined)
    combined = enforce_h2_emojis(combined, flag)

    new_title = f"{dest} Gezi Rehberi {flag}"
    focuskw = f"{dest} gezi rehberi"

    # ══════════════════════════════════════════════════════════════════════
    # ADIM 14: WP GÜNCELLE
    # ══════════════════════════════════════════════════════════════════════
    print("   📤 ADIM 14: WordPress'e yazılıyor...")
    try:
        update_post_complete(
            pid, new_title, combined,
            close_comments=True,
            update_date=True,
            yoast_title=yoast_title,
            yoast_desc=yoast_desc,
            yoast_focuskw=focuskw,
            categories=orig_cats or None
        )
        print(f"      ✅ Post ID {pid} güncellendi")
        print(f"      📝 H1: {new_title}")
        update_yoast_meta(pid, yoast_title, yoast_desc, focuskw)
        deleted = delete_post_comments(pid)
        if deleted: print(f"      🗑️  {deleted} yorum silindi")
    except Exception as e:
        print(f"      ⚠️  WordPress hatası: {e}")

    print(f"\n   ✅ GUIDE MOD TAMAMLANDI")
    return combined


# Yardımcı fonksiyon: wrap_paras_inline (basit paragraf sarma)
    """
    GUIDE modu — Destinasyon Gezi Rehberi formatı:
    - H1: {Destinasyon} Gezi Rehberi {🇹🇷}
    - Giriş 2§
    - H2: Hakkında Bilgiler
    - H2: Nerede? Nasıl Gidilir?
    - H2: Gezilecek Yerler (H3 listesi)
    - H2: Gezi Planı
    - H2: Yeme İçme Rehberi
    - H2: Konaklama Önerileri
    - H2: Alışveriş Rehberi
    - H2: Pratik Bilgiler ve İpuçları
    - Kapanış 2§
    - FAQ + Schema (7 soru)
    """
