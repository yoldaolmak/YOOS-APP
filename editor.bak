        '</ul>'
    )


# ─── STANDALONE SCHEMA + FAQ EKLEME MODÜLÜ ───────────────────────────────────
def add_schema_faq_to_post(post_id: int, mode: str = 'auto') -> bool:
    """
    Verilen POST ID'ye Schema + FAQ bloğu ekle (post sonuna).
    
    mode:
        'auto'  → Post içeriğinden mod tespit et (H2 başlıklarına göre)
        'where' → WHERE mod soru seti
        'guide' → GUIDE mod soru seti
    
    Returns:
        True → başarılı
        False → hata
    """
    from wp import get_post
    try:
        # Post al
        post = get_post(post_id)
        if not post:
            print(f"❌ Post ID {post_id} bulunamadı")
            return False
        
        title   = post['title']['rendered']
        content = post['content']['rendered']
        dest    = extract_dest(title)
        flag    = get_flag(dest)
        today   = datetime.now().strftime('%Y-%m-%d')
        
        print(f"\n📋 SCHEMA + FAQ EKLEME: {dest} {flag}")
        print(f"   🆔 Post ID: {post_id}")
        
        # Mod tespiti
        if mode == 'auto':
            # H2 başlıklarına göre mod belirle
            if 'Gezilecek Yerler' in content and 'Yeme İçme' in content and 'Konaklama' in content:
                mode = 'guide'
                print(f"   🤖 Mod: GUIDE (otomatik tespit)")
            elif 'Nasıl Bir Yer' in content or 'Nasıl Gidilir' in content:
                mode = 'where'
                print(f"   🤖 Mod: WHERE (otomatik tespit)")
            else:
                mode = 'where'  # Varsayılan
                print(f"   🤖 Mod: WHERE (varsayılan)")
        else:
            print(f"   🤖 Mod: {mode.upper()} (manuel)")
        
        # Yoast meta (varsa kullan, yoksa oluştur)
        if mode == 'guide':
            yoast_title, yoast_desc = build_yoast_meta_guide(dest)
        else:
            yoast_title, yoast_desc = build_yoast_meta(dest)
        
        # Schema + FAQ oluştur
        print(f"   ❓ FAQ + Schema oluşturuluyor...")
        faq_schema_html = build_faq_schema(dest, mode, yoast_title, yoast_desc, today)
        
        # Post sonuna ekle (eğer zaten varsa ekleme)
        if 'yoa-faq-schema' in content:
            print(f"   ⚠️  Post zaten FAQ + Schema içeriyor, güncelleniyor...")
            # Eski schema'yı sil, yenisini ekle
            import re
            content = re.sub(
                r'<!-- wp:html -->\s*<div class="yoa-faq-schema".*?</div>\s*<!-- /wp:html -->',
                '',
                content,
                flags=re.DOTALL
            )
        
        # Sonuna ekle
        new_content = content.strip() + "\n\n" + faq_schema_html
        
        # WordPress'e yaz
        print(f"   📤 Post güncelleniyor...")
        update_post_complete(
            post_id,
            title,
            new_content,
            close_comments=False,
            update_date=False,
        )
        print(f"   ✅ Schema + FAQ eklendi ({len(faq_schema_html)} karakter)")
        return True
        
    except Exception as e:
        print(f"   ❌ Hata: {e}")
        import traceback
        traceback.print_exc()
        return False


# ─── SCHEMA + FAQ (faq-schema-prompt.txt) ────────────────────────────────────
# Soru setleri mod bazlı; AI cevap üretir; Article + FAQPage; mavi tema.

_FAQ_QUESTIONS = {
    'where': [
        # WHERE modda H2 başlıkları: Nasıl Bir Yer / Nerede / Nasıl Gidilir / Gezi Planı
        # SEO odaklı, ulaşım ve konum ağırlıklı
        ("✈️", "{dest}'a nasıl gidilir, hangi havayolları uçuyor?"),
        ("🗺️", "{dest} nerede, hangi ülkede ve bölgede?"),
        ("🏙️", "{dest} nasıl bir yer, karakteri nedir?"),
        ("🚌", "{dest} havalimanından şehir merkezine nasıl gidilir?"),
        ("📅", "{dest} için kaç gün yeterli, ne zaman gidilmeli?"),
        ("💰", "{dest} pahalı mı, günlük bütçe ne kadar?"),
        ("🛂", "{dest} vize istiyor mu, Türk pasaportu geçerli mi?"),
    ],
    'guide': [
        # GUIDE modda H2 başlıkları: Gezi Rehberi / Gezilecek Yerler / Yeme İçme / Konaklama / Alışveriş / Pratik Bilgiler
        # SEO odaklı, destinasyon bilgisi ve gezi içeriği ağırlıklı
        ("📍", "{dest}'de mutlaka görülmesi gereken yerler hangileri?"),
        ("🍽️", "{dest}'de ne yenir, yerel mutfak nasıl?"),
        ("🏨", "{dest}'de nerede kalınmalı, en iyi bölgeler neresi?"),
        ("🛍️", "{dest}'den ne alınır, alışveriş önerileri neler?"),
        ("📅", "{dest}'e ne zaman gidilmeli, en iyi mevsim hangisi?"),
        ("🏛️", "{dest} neden önemli, tarihi ve kültürel önemi nedir?"),
        ("🛂", "{dest} vize istiyor mu?"),  # Türkiye'de elenir
    ],
}

_FAQ_ANSWER_RULES = """
FAQ CEVAP KURALLARI:
- 1-2 cümle, maksimum 250 karakter
- Bilgilendirici, samimi, net
- Sadece bilgi, şiirsel anlatım yok
→ bkz. DIL_KURALLARI (yasak kelimeler, bold)

CEVAP ŞABLONLARı:
"NEREDE": "{dest}, {ülke}'nin {bölge} bölgesinde, {coğrafya} kıyısında yer alır."
"NASIL GİDİLİR": "Türkiye'den {havayolu} ile {direkt/aktarmalı} uçuşlar var. Uçuş süresi yaklaşık <strong>X saat</strong>."
"KAÇ GÜN": "Ana noktalar için <strong>X-Y gün</strong> yeterli. Çevre eklenirse <strong>Z gün</strong> ayırmalısınız."
"NE ZAMAN": "En ideal dönem <strong>Ay-Ay</strong> arası. Kış/yaz aylarında {hava} yaşanabilir."
"VİZE": "Evet/Hayır, {vize durumu}. {süreç}"
"""

def _strip_html(text: str) -> str:
    """Schema cevaplarından HTML taglarını temizle"""
    return re.sub(r'<[^>]+>', '', text).strip()

def generate_faq_pairs(dest: str, mode: str) -> list[tuple[str, str]]:
    """
    WHERE ve GUIDE için ayrı soru seti. Türkiye filtresi burada uygulanır.
    Returns: [(emoji+soru, cevap), ...]
    """
    # Mode'a göre soru seti seç, bilinmeyen mod → where
    raw_list = _FAQ_QUESTIONS.get(mode, _FAQ_QUESTIONS['where'])

    # Türkiye filtresi
    _is_tr = (get_flag(dest) == '')
    if _is_tr:
        raw_list = [
            (emoji, q) for emoji, q in raw_list
            if not any(kw in q.lower() for kw in ['vize', 'saat farkı', 'pasaport'])
        ]
        if not any('ünlü' in q.lower() or 'meşhur' in q.lower() or 'önemli' in q.lower()
                   for _, q in raw_list):
            raw_list = list(raw_list) + [("🏛️", "{dest} neden ünlü, öne çıkan özellikleri neler?")]

    questions  = [(emoji, q.replace('{dest}', dest)) for emoji, q in raw_list]
    q_json = "[" + ", ".join(f'"{q}"' for _, q in questions) + "]"

    prompt = (
        f"SEN: Yoldaolmak.com seyahat blog yazarısın.\n"
        f"GÖREV: {dest} için aşağıdaki {len(questions)} soruya kısa, bilgilendirici cevaplar yaz.\n\n"
        f"KURALLAR:\n"
        f"- Her cevap 1-2 cümle, maksimum 220 karakter\n"
        f"- Rakamlar, süreler, mevsimler için <strong>tag</strong> kullan\n"
        f"- Samimi, net, yalnızca bilgi\n\n"
        f"SORULAR: {q_json}\n\n"
        f"CIKTI: Yalnizca JSON array, baska HİÇBİR SEY YAZMA:\n"
        f'[{{"s": "soru metni", "c": "cevap metni"}}, ...]\n'
    )

    raw = ask_gpt_only(prompt, max_tokens=1200)
    # NOT: clean_html KULLANMA — JSON içindeki <strong> taglarını siler
    raw = raw.strip()

    # ── Parse: JSON dene ─────────────────────────────────────────────────
    pairs = []
    try:
        raw_clean = re.sub(r'```(?:json)?\s*', '', raw).replace('```', '').strip()
        m = re.search(r'(\[.*\])', raw_clean, re.DOTALL)
        if m:
            data = json.loads(m.group(1))
            for idx, item in enumerate(data):
                q_text = item.get('s') or item.get('soru') or item.get('question') or ''
                a_text = item.get('c') or item.get('cevap') or item.get('answer') or ''
                q_text = q_text.strip()
                a_text = a_text.strip()
                if q_text and a_text:
                    if len(_strip_html(a_text)) > 260:
                        a_text = a_text[:250] + '...'
                    # Emoji'yi soru başına ekle (eğer yoksa)
                    emoji = questions[idx][0] if idx < len(questions) else "❓"
                    if not q_text.startswith(emoji):
                        q_text = f"{emoji} {q_text}"
                    pairs.append((q_text, a_text))
    except Exception as _je:
        print(f"      ⚠️  FAQ JSON parse hatası: {_je}")

    # ── Fallback: statik ─────────────────────────────────────────────────
    if not pairs:
        print("      ⚠️  FAQ parse edilemedi — statik fallback")
        for emoji, q in questions:
            pairs.append((f"{emoji} {q}", f"{dest} hakkında güncel bilgi için resmi turizm kaynaklarını inceleyin."))

    print(f"      ✅ FAQ üretildi: {len(pairs)} soru-cevap çifti")
    return pairs

def build_faq_schema(
    dest:      str,
    mode:      str,          # 'where' | 'guide'
    headline:  str = "",
    meta_desc: str = "",
    today:     str = "2026-02-13"
) -> str:
    """
    WHERE ve GUIDE için ayrı FAQ + Article + FAQPage schema bloğu.
    """
    if not headline:
        if mode == 'guide':
            headline = f"{dest} Gezi Rehberi"
        else:
            headline = f"{dest} Nasıl Bir Yer? Nerede, Nasıl Gidilir, Gezi Planı"
    if not meta_desc:
        if mode == 'guide':
            meta_desc = (f"{dest} gezi rehberi: gezilecek yerler, ne yenir, "
                         f"ne alınır, konaklama ve pratik bilgiler.")
        else:
            meta_desc = (f"{dest} nerede, nasıl gidilir? "
                         f"{dest} nasıl bir yer, gezi planı ve ulaşım rehberi.")

    # AI ile cevap üret
    pairs = generate_faq_pairs(dest, mode)

    # ── HTML FAQ item'ları ───────────────────────────────────────────────
    items_html_parts = []
    for idx, (q, a) in enumerate(pairs):
        is_last = (idx == len(pairs) - 1)
        # Son item'da border-bottom YOK
        style = 'padding:14px 0;' if is_last else 'border-bottom:1px solid #d1e3f0;padding:14px 0;'
        items_html_parts.append(
            f'  <div style="{style}">\n'
            f'    <p style="font-weight:700;margin:0 0 6px;color:#0f3460;">{q}</p>\n'
            f'    <p style="margin:0;color:#374151;line-height:1.6;">{a}</p>\n'
            f'  </div>'
        )
    items_html = '\n'.join(items_html_parts)

    # ── Article schema ───────────────────────────────────────────────────
    article_schema = {
        "@context": "https://schema.org",
        "@type": "Article",
        "headline": headline,
        "description": meta_desc,
        "datePublished": today,
        "author": {"@type": "Person", "name": "Kemal Kaya"},
        "publisher": {
            "@type": "Organization",
            "name": "Yoldaolmak.com",
            "logo": {
                "@type": "ImageObject",
                "url": "https://yoldaolmak.com/logo.png"
            }
        }
    }

    # ── FAQPage schema (cevaplarda HTML etiket temizle) ──────────────────
    faq_entities = [
        {
            "@type": "Question",
            "name": q,
            "acceptedAnswer": {"@type": "Answer", "text": _strip_html(a)}
        }
        for q, a in pairs
    ]
    faq_schema = {
        "@context": "https://schema.org",
        "@type": "FAQPage",
        "mainEntity": faq_entities
    }

    # ── Tek wp:html bloğu ────────────────────────────────────────────────
    return (
        '<!-- wp:html -->\n'
        '<div class="yoa-faq-schema" style="border:2px solid #0073aa;'
        'border-radius:10px;padding:24px 28px;margin:2.5em 0;background:#f0f7ff;">\n'
        f'  <h3 style="margin:0 0 18px;color:#0073aa;font-size:1.15em;font-weight:700;">'
        f'📋 {dest} Hakkında Sık Sorulan Sorular</h3>\n\n'
        f'{items_html}\n\n'
        '  <script type="application/ld+json">\n'
        f'{json.dumps(article_schema, ensure_ascii=False, indent=2)}\n'
        '  </script>\n'
        '  <script type="application/ld+json">\n'
        f'{json.dumps(faq_schema, ensure_ascii=False, indent=2)}\n'
        '  </script>\n'
        '</div>\n'
        '<!-- /wp:html -->'
    )


