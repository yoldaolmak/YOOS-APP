_TR_NORMALIZE = [
    ('İ','i'),('I','i'),('Ğ','g'),('Ş','s'),('Ç','c'),('Ö','o'),('Ü','u'),
    ('ğ','g'),('ş','s'),('ç','c'),('ö','o'),('ü','u'),('ı','i'),
]

# Türkçe ek kalıpları: 'nın, 'de, 'da, 'ta, 'te, 'e, 'a, 'ı, 'i, 'u, 'ü, 'ye, 'ya vb.
_DEST_SUFFIX_RE = re.compile(r"['\u2019][a-züğışçöA-ZÜĞİŞÇÖ]{1,4}$")
# Başlıkta destinasyonu kesen tetikleyici kelimeler
_DEST_SPLIT_WORDS = [
    'Nerede', 'Nasıl', 'Nasil', 'Gezilecek', 'Gezi Rehberi',
    'Rehberi', 'Hakkında', 'Hakkinda',
]

def extract_dest(title: str) -> str:
    """
    Post başlığından destinasyon adını temizleyerek çıkar.

    'Dubrovnik Nerede'       → 'Dubrovnik'
    'Belem Gezilecek Yerler' → 'Belem'
    "Dubrovnik'e Nasıl Gidilir" → 'Dubrovnik'
    'Split Hakkında'         → 'Split'
    '&#8217;' gibi HTML entity apostrof da temizlenir.
    """
    s = title.replace('&#8217;', "\u2019").replace('&#039;', "'")
    for word in _DEST_SPLIT_WORDS:
        idx = s.find(word)
        if idx != -1:
            s = s[:idx]
    s = s.strip()
    # Apostrof + Türkçe ek sonu: "Dubrovnik'e" → "Dubrovnik"
    s = _DEST_SUFFIX_RE.sub('', s).strip()
    return s


def get_flag(dest: str) -> str:
    key = dest.strip()
    for a, b in _TR_NORMALIZE:
        key = key.replace(a, b)
    key = key.lower()
    key = re.sub(r'[\s_]+', '_', key).strip('_')
    return _FLAGS.get(key, '🌍')

def is_where_post(title: str) -> bool:
    t = title.lower()
    return 'nerede' in t or 'nasil gidilir' in t or 'nasıl gidilir' in t


# ─── AI ROUTER ────────────────────────────────────────────────────────────────
def ask_ai(prompt, max_tokens=16000):
    """
    Akıllı AI motor seçimi - Claude veya GPT
    
    Args:
        prompt: AI'ya gönderilecek prompt
        max_tokens: Maksimum token sayısı
    
    Returns:
        str: AI'ın yanıtı
    """
    global AI_ENGINE
    
    # AUTO mod: Claude dene, başarısızsa GPT
    if AI_ENGINE == "auto":
        try:
            return ask_claude(prompt, max_tokens=max_tokens, model="claude-sonnet-4-20250514")
        except Exception as e:
            print(f"      ⚠️  Claude hatası: {str(e)[:50]}")
            print(f"      🔄 GPT-4o'ya geçiliyor...")
            from openai_engine import ask_gpt
            return ask_gpt(prompt, max_tokens=max_tokens, model="gpt-4o")
    
    # GPT mod
    elif AI_ENGINE == "gpt":
        from openai_engine import ask_gpt
        return ask_gpt(prompt, max_tokens=max_tokens, model="gpt-4o")
    
    # Claude mod (varsayılan)
    else:
        return ask_claude(prompt, max_tokens=max_tokens, model="claude-sonnet-4-20250514")

def ask_claude_only(prompt, max_tokens=4000):
    """
    DAIMA Claude — Ses/kimlik korunan bölümler:
    giriş 2 paragraf, kişisel bakış.
    AUTO modda bile Claude override edilmez.
    """
    return ask_claude(prompt, max_tokens=max_tokens, model="claude-sonnet-4-20250514")

def ask_gpt_only(prompt, max_tokens=4000):
    """
    DAIMA GPT-4o — Bilgi ağırlıklı, düşük maliyetli bölümler:
    Nasıl Bir Yer, Nerede, Nasıl Gidilir, Gezi Planı, Kapanış.
    AI_ENGINE ne olursa olsun GPT kullanır.
    """
    from openai_engine import ask_gpt
    return ask_gpt(prompt, max_tokens=max_tokens, model="gpt-4o")

def safe_gpt(prompt, original, max_tokens=4000, min_chars=None):
    """safe_ai'in GPT-only versiyonu — WHERE mod bilgi bölümleri için."""
    try:
        result = ask_gpt_only(prompt, max_tokens=max_tokens)
        result = clean_html(result)
        result = fix_md_bold_italic(result)
        if not result or len(result.strip()) < 80:
            print("      ⚠️  GPT boş cevap → orijinal"); return original
        if min_chars is not None and len(result) < min_chars:
            print(f"      ⚠️  GPT kısa ({len(result)}<{min_chars}) → orijinal"); return original
        return result
    except Exception as e:
        print(f"      ❌ GPT: {e} → orijinal"); return original

def safe_ai(prompt, original, max_tokens=16000, min_ratio=0.70, min_chars=None):
    try:
        result = ask_ai(prompt, max_tokens=max_tokens)
        result = clean_html(result)
        result = fix_md_bold_italic(result)
        if not result or len(result.strip()) < 80:
            print("      ⚠️  Boş cevap → orijinal"); return original
        if min_chars is not None:
            if len(result) < min_chars:
                print(f"      ⚠️  Kısa ({len(result)}<{min_chars}) → orijinal"); return original
            return result
        if len(result) < len(original) * min_ratio:
            print(f"      ⚠️  Kısa (%{int(len(result)/len(original)*100)}) → orijinal"); return original
        return result
    except Exception as e:
        print(f"      ❌ AI: {e} → orijinal"); return original


# ─── HTML YARDIMCILAR ─────────────────────────────────────────────────────────

def check_giris_kalip(html: str, dest: str) -> list[str]:
    """
    GPT çıktısında kalıp giriş tespit eder.
    Sorun bulursa liste döner, temizse [] döner.
    """
    issues = []
    check_str = html.lower()
    kaliplar = [
        ("herkes bir şey söyledi",  "Kalıp giriş: 'herkes bir şey söyledi'"),
        ("ama eksik anlattılar",     "Kalıp giriş: 'eksik anlattılar'"),
        ("beklediğim gibi değildi",  "Kalıp: 'beklediğim gibi değildi'"),
        ("kendi yolunu bulur",       "Kalıp: 'kendi yolunu bulur'"),
        ("—",                        "Tire '—' kullanımı"),
        ("davet ediyorum",           "Influencer kapanış: 'davet ediyorum'"),
        ("kaçırmayın",               "Hard imperative: 'kaçırmayın'"),
        ("mutlaka görün",            "Hard imperative: 'mutlaka görün'"),
        ("eksik anlattı",            "Kalıp varyantı: 'eksik anlattı'"),
        ("haklıydılar",              "Kalıp varyantı: 'haklıydılar'"),
        ("zaman yolculuğu",          "Kalıp: 'zaman yolculuğu'"),
        ("kaybolmanın keyfine",      "Kalıp: 'kaybolmanın keyfine'"),
        ("atmosferinde kaybol",      "Kalıp: 'atmosferinde kaybol'"),
    ]
    for pattern, label in kaliplar:
        if pattern.lower() in check_str:
            issues.append(label)
    return issues

def auto_fix_gpt_output(html: str) -> str:
    """
    GPT çıktısındaki bilinen sorunları otomatik düzelt:
    - Tire '—' → boşlukla kaldır
    - Markdown başlıklar → Gutenberg H2/H3
    - Yasak kelimeleri sil
    """
    import re as _re
    # 1. Tire — H3 basligindaki 'N. Ad — Tanim' formatini KORU
    _h3_stash = {}
    _h3_idx   = [0]
    def _stash_h3(m):
        key = f'\x00H3STASH{_h3_idx[0]}\x00'
        _h3_stash[key] = m.group(0)
        _h3_idx[0] += 1
        return key
    html = _re.sub(r'<h3[^>]*>.*?</h3>', _stash_h3, html,
                   flags=_re.DOTALL | _re.IGNORECASE)
    html = _re.sub(r'\s*[\u2014\u2013]\s*', ' ', html)  # metin ici tire temizle
    for key, val in _h3_stash.items():
        html = html.replace(key, val)  # H3'leri geri koy
    # 2. Markdown H2 → Gutenberg
    def _md_h2(m):
        text = m.group(1).strip()
        return (
            '<!-- wp:separator -->\n'
            '<hr class="wp-block-separator has-alpha-channel-opacity"/>\n'
            '<!-- /wp:separator -->\n'
            '<!-- wp:heading {"level":2} -->\n'
            f'<h2 class="wp-block-heading"><strong>{text}</strong></h2>\n'
            '<!-- /wp:heading -->'
        )
    def _md_h3(m):
        text = m.group(1).strip()
        return (
            '<!-- wp:heading {"level":3} -->\n'
            f'<h3 class="wp-block-heading"><strong>{text}</strong></h3>\n'
            '<!-- /wp:heading -->'
        )
    html = _re.sub(r'^## (.+)$', _md_h2, html, flags=_re.MULTILINE)
    html = _re.sub(r'^### (.+)$', _md_h3, html, flags=_re.MULTILINE)
    html = _re.sub(r'^#### (.+)$', _md_h3, html, flags=_re.MULTILINE)
    # 3. Markdown bold/italic → HTML (wrap_gutenberg bunu zaten yapıyor ama ekstra güvenlik)
    html = _re.sub(r'\*\*(.+?)\*\*', r'<strong>\1</strong>', html)
    html = _re.sub(r'\*(.+?)\*', r'<em>\1</em>', html)
    # 4. Yasak kelimeler
    for bw in BANNED_WORDS:
        html = _re.sub(rf'\b{_re.escape(bw)}\b\s*', '', html, flags=_re.IGNORECASE)
    # 5. <img> loading=lazy kaldır (<iframe>'e dokunma)
    html = _re.sub(
        r'(<img[^>]*?)[ ]+loading=["\']lazy["\']([ ]*[/]?>)',
        r'\1\2', html, flags=_re.IGNORECASE
    )
    return html

def clean_html(text: str) -> str:
    text = re.sub(r'^```html\s*\n?', '', text, flags=re.MULTILINE)
    text = re.sub(r'\n?```\s*$',     '', text, flags=re.MULTILINE)
    text = text.replace('```html','').replace('```','')
    return text.strip()

def fix_md_bold_italic(text: str) -> str:
    text = re.sub(r'\*\*\*(.*?)\*\*\*', r'<strong><em>\1</em></strong>', text)
    text = re.sub(r'\*\*(.*?)\*\*',     r'<strong>\1</strong>', text)
    text = re.sub(r'(?<!\*)\*(?!\*)(.*?)(?<!\*)\*', r'<em>\1</em>', text)
    return text

def strip_gutenberg(html: str) -> str:
    return re.sub(r'<!--\s*/?wp:[^>]*-->', '', html).strip()

def _close_unclosed_p(html: str) -> str:
    """AI çıktısındaki kapanmamış <p> taglarını kapat"""
    lines = html.split('\n')
    result = []
    for line in lines:
        # <p> açılmış ama satır </p> ile bitmiyor ve satırda başka kapanış yok
        if re.search(r'<p[^>]*>', line, re.I) and not re.search(r'</p>', line, re.I):
            line = line.rstrip() + '</p>'
        result.append(line)
    return '\n'.join(result)

def wrap_gutenberg(html: str) -> str:
    """
    Ham HTML → Gutenberg blokları.
    Kritik düzeltmeler:
    0. Mevcut <!-- wp:html -->...<!-- /wp:html --> blokları ÖNCE sakla
       (rich maps box gibi nested div içerenler parçalanmaz)
    1. Kalan <div> blokları stash → basit Maps div parçalanmaz
    2. <h2>/<h3> sonrasındaki düz metin → ayrı wp:paragraph bloğu
    3. Kapanmamış <p> tagları otomatik kapatılır
    """
    # ── ADIM 0: ÖNCE wp:html bloklarını sakla ────────────────────────────
    # strip_gutenberg wp:html yorum taglarını siler — ondan ÖNCE stash edilmeli
    # (rich maps box, FAQ schema gibi nested-div içeren bloklar korunur)
    wph_stash: list[str] = []
    def _stash_wph(m: re.Match) -> str:
        inner = re.sub(r'<!--\s*/?wp:html\s*-->', '', m.group(0)).strip()
        wph_stash.append(inner)
        return f'\x00WPH{len(wph_stash)-1}\x00'
    html = re.sub(
        r'<!--\s*wp:html\s*-->.*?<!--\s*/wp:html\s*-->',
        _stash_wph, html, flags=re.DOTALL
    )

    html = strip_gutenberg(html)      # Geri kalan wp: yorumları sil
    html = _close_unclosed_p(html)

    # Adım 1: Toplevel <div> bloklarını ayır (içlerinde iframe olabilir)
    div_stash = []
    def stash_div(m):
        div_stash.append(m.group(0))
        return f'\x00DIV{len(div_stash)-1}\x00'
    html_nodiv = re.sub(r'<div[^>]*>.*?</div>', stash_div, html,
                        flags=re.DOTALL|re.IGNORECASE)

    # Adım 2: Normal elementleri tokenize et (div hariç)
    # KRITIK: WPH placeholder sınırlarında da böl —
    # aksi hâlde son <p>...\x00WPH0\x00 token'ı paragraf içine sıkışır
    raw_tokens = re.split(
        r'(?=<(?:p|h[1-6]|hr|ul|ol|figure|script)[^>]*>)',
        html_nodiv
    )
    tokens = []
    _wph_re = re.compile(r'(\x00WPH\d+\x00)')
    for _rt in raw_tokens:
        if '\x00WPH' in _rt:
            # \x00WPHn\x00 sınırlarında böl, placeholder ayrı token
            _parts = _wph_re.split(_rt)
            tokens.extend(_p for _p in _parts if _p)
        else:
            tokens.append(_rt)

    out = []
    for tok in tokens:
        tok = tok.strip()
        if not tok: continue

        # WPH placeholder → doğrudan çıkar, son restore adımı halleder
        if _wph_re.fullmatch(tok):
            out.append(tok); continue

        # Zaten Gutenberg yorum bloğu → dokunma
        if tok.startswith('<!--'):
            out.append(tok); continue

        # DIV placeholder → wp:html bloğu olarak geri koy
        if '\x00DIV' in tok:
            def _restore(m):
                d = div_stash[int(m.group(1))]
                return f'<!-- wp:html -->\n{d}\n<!-- /wp:html -->'
            tok = re.sub(r'\x00DIV(\d+)\x00', _restore, tok)
            out.append(tok); continue

        # <h2> / <h3>: sadece tag → heading bloğu; sonraki metin → paragraf bloğu
        hm = re.match(r'(<h([23])[^>]*>.*?</h\2>)(.*)', tok,
                      re.IGNORECASE|re.DOTALL)
        if hm:
            lvl   = hm.group(2)
            htag  = hm.group(1)
            after = hm.group(3).strip()
            if lvl == '2':
                out.append('<!-- wp:separator -->\n'
                            '<hr class="wp-block-separator has-alpha-channel-opacity"/>\n'
                            '<!-- /wp:separator -->')
            out.append(f'<!-- wp:heading {{"level":{lvl}}} -->\n{htag}\n<!-- /wp:heading -->')
            if after:
                for chunk in re.split(r'\n{2,}', after):
                    chunk = chunk.strip()
                    if not chunk: continue
                    if re.match(r'<p[^>]*>', chunk, re.I):
                        if not chunk.rstrip().endswith('</p>'): chunk += '</p>'
                        out.append(f'<!-- wp:paragraph -->\n{chunk}\n<!-- /wp:paragraph -->')
                    elif re.match(r'<(?:ul|ol)[^>]*>', chunk, re.I):
                        tag = 'list {"ordered":true}' if chunk.startswith('<ol') else 'list'
                        out.append(f'<!-- wp:{tag} -->\n{chunk}\n<!-- /wp:list -->')
                    elif re.match(r'<h3[^>]*>', chunk, re.I):
                        out.append(f'<!-- wp:heading {{"level":3}} -->\n{chunk}\n<!-- /wp:heading -->')
                    else:
                        out.append(f'<!-- wp:paragraph -->\n<p>{chunk}</p>\n<!-- /wp:paragraph -->')
            continue

        # <p>
        if re.match(r'^<p[^>]*>', tok, re.I):
            if not tok.rstrip().endswith('</p>'): tok += '</p>'
            out.append(f'<!-- wp:paragraph -->\n{tok}\n<!-- /wp:paragraph -->')
        elif re.match(r'^<hr[^>]*/?>$', tok.split('\n')[0], re.I):
            out.append('<!-- wp:separator -->\n'
                       '<hr class="wp-block-separator has-alpha-channel-opacity"/>\n'
                       '<!-- /wp:separator -->')
        elif re.match(r'^<ul[^>]*>', tok, re.I):
            out.append(f'<!-- wp:list -->\n{tok}\n<!-- /wp:list -->')
        elif re.match(r'^<ol[^>]*>', tok, re.I):
            out.append(f'<!-- wp:list {{"ordered":true}} -->\n{tok}\n<!-- /wp:list -->')
        elif re.match(r'^<figure[^>]*>', tok, re.I):
            out.append(f'<!-- wp:image -->\n{tok}\n<!-- /wp:image -->')
        elif re.match(r'^<(?:script|iframe)', tok, re.I):
            out.append(f'<!-- wp:html -->\n{tok}\n<!-- /wp:html -->')
        else:
            # Orphan düz metin / inline element → wp:paragraph'a sar
            stripped = tok.strip()
            if not stripped:
                continue
            if re.match(r'^<(?:script|style|div|table|thead|tbody|tr|td|th)', stripped, re.I):
                out.append(stripped)
            else:
                if not re.match(r'^<p[\s>]', stripped, re.I):
                    stripped = '<p>' + stripped + '</p>'
                out.append('<!-- wp:paragraph -->\n' + stripped + '\n<!-- /wp:paragraph -->')

    result = '\n\n'.join(out)

    # ADIM SON: WPH restore — saf HTML'i wp:html bloğu olarak geri koy
    if wph_stash:
        def _restore_wph(m: re.Match) -> str:
            return f'<!-- wp:html -->\n{wph_stash[int(m.group(1))]}\n<!-- /wp:html -->'
        result = re.sub(r'\x00WPH(\d+)\x00', _restore_wph, result)

    # SON KONTROL: Gutenberg etiketi olmayan orphan <p> taglarını sar
    def _fix_orphan_p(m):
        pos   = m.start()
        chunk = result[max(0, pos - 80) : pos]
        if '<!-- wp:paragraph -->' in chunk:
            return m.group(0)  # zaten sarılı
        return f'<!-- wp:paragraph -->\n{m.group(0)}\n<!-- /wp:paragraph -->'
    result = re.sub(r'<p>(?:(?!<p>).)+?</p>', _fix_orphan_p, result, flags=re.DOTALL)

    return result


def validate_gutenberg(html: str) -> str:
    """G4: Gutenberg bloğu dışında kalan bare <p> taglarını sar."""
    result = re.sub(
        r'(?<!<!-- wp:paragraph -->\n)(<p\b[^>]*>(?:(?!<p\b).)+?</p>)',
        lambda m: (
            m.group(0) if
            html[:m.start()].rstrip().endswith('<!-- wp:paragraph -->')
            else f'<!-- wp:paragraph -->\n{m.group(0)}\n<!-- /wp:paragraph -->'
        ),
        html, flags=re.DOTALL
    )
    return result

def enforce_h_bold(html: str) -> str:
    def wrap(m):
        o, inner, c = m.group(1), m.group(2), m.group(3)
        if '<strong>' in inner: return m.group(0)
        return f'{o}<strong>{inner}</strong>{c}'
    return re.sub(r'(<h[23][^>]*>)(.*?)(</h[23]>)', wrap, html,
                  flags=re.IGNORECASE|re.DOTALL)

def check_banned(text: str) -> list:
    issues = []
    # BANNED_WORDS kontrolu (tam metin)
    for w in BANNED_WORDS:
        if w.lower() in text.lower(): issues.append(f"KEL:{w}")
    # BANNED_PHRASES: H3 basliklarini cikart (tire H3'te serbest)
    text_no_h3 = re.sub(r'<h3[^>]*>.*?</h3>', '', text, flags=re.DOTALL | re.IGNORECASE)
    for p in BANNED_PHRASES:
        if re.search(p, text_no_h3, re.IGNORECASE): issues.append(f"CUMLE:{p}")
    return issues

# ─── AYIRAÇ (Where.txt §4 & §10: SADECE H2 ÖNCESİNDE) ───────────────────────
SEP = '<hr class="wp-block-separator has-alpha-channel-opacity"/>'

def title_case_tr(text: str) -> str:
    """Türkçe title case: her kelimenin baş harfi büyük (i→İ, ı→I vb.)."""
    TR_UPPER = {'i': 'İ', 'ı': 'I', 'ş': 'Ş', 'ç': 'Ç', 'ğ': 'Ğ', 'ö': 'Ö', 'ü': 'Ü'}
    words = text.split(' ')
    out = []
    for w in words:
        if not w:
            out.append(w)
            continue
        first = TR_UPPER.get(w[0], w[0].upper())
        out.append(first + w[1:])
    return ' '.join(out)


def capitalize_h_titles(html: str) -> str:
    """
    H2 ve H3 başlıklarındaki metni Türkçe title case'e çevir.
    HTML tag'leri, emoji ve özel karakterleri korur.
    """
    def _cap_inner(inner: str) -> str:
        # HTML parçalara böl: tag vs metin
        parts = re.split(r'(<[^>]+>)', inner)
        result = []
        for p in parts:
            if p.startswith('<'):
                result.append(p)
            elif p.strip():
                result.append(title_case_tr(p))
            else:
                result.append(p)
        return ''.join(result)

    def _cap_heading(m):
        return m.group(1) + _cap_inner(m.group(2)) + m.group(3)

    return re.sub(
        r'(<h[23][^>]*>)(.*?)(</h[23]>)',
        _cap_heading,
        html,
        flags=re.DOTALL | re.IGNORECASE
    )


def dedup_separators(html: str) -> str:
    """Ard arda gelen birden fazla separator bloğunu teke indir."""
    SEP_PAT = (
        r'(?:'
        r'<!-- wp:separator -->\s*'
        r'<hr[^/]*/>\s*'
        r'<!-- /wp:separator -->\s*'
        r')+'
    )
    SEP_ONE = (
        '<!-- wp:separator -->\n'
        '<hr class="wp-block-separator has-alpha-channel-opacity"/>\n'
        '<!-- /wp:separator -->\n'
    )
    return re.sub(SEP_PAT, SEP_ONE, html, flags=re.IGNORECASE | re.DOTALL)

# Gezi Rehberi başlıklarında yasak emojiler (sadece bayrak kalacak)
_H2_BANNED_EMOJIS = re.compile(
    r'[\U00002702-\U000027B0\U0001F300-\U0001F9FF'   # geniş emoji aralığı
    r'\U00002600-\U000026FF]',                          # semboller
    re.UNICODE
)

def _strip_h2_emojis(text: str, keep: str = "") -> str:
    """H2 başlık metnindeki emojileri temizle; keep değerini koru."""
    cleaned = _H2_BANNED_EMOJIS.sub("", text).strip()
    return cleaned

def add_flag_to_first_h2(html: str, flag: str) -> str:
    """
    İlk H2 başlığını standardize et:
    1. Mevcut emojileri temizle (✈️ 🌍 🏛️ vb.)
    2. Sonuna bayrak ekle (yoksa)
    """
    if not html:
        return html
    first = re.search(r'(<h2[^>]*>)(.*?)(</h2>)', html, re.DOTALL | re.IGNORECASE)
    if not first:
        return html
    inner = first.group(2)
    # <strong> içeriğini temizle
    if '</strong>' in inner:
        inner = re.sub(
            r'(<strong>)(.*?)(</strong>)',
            lambda m: m.group(1) + _strip_h2_emojis(m.group(2)) + m.group(3),
            inner, flags=re.DOTALL
        )
    else:
        inner = _strip_h2_emojis(inner)
    # Bayrak ekle (yoksa)
    if flag and flag not in inner:
        if '</strong>' in inner:
            inner = inner.rstrip().replace('</strong>', f' {flag}</strong>', 1)
        else:
            inner = inner.rstrip() + ' ' + flag
    replacement = first.group(1) + inner + first.group(3)
    return html[:first.start()] + replacement + html[first.end():]


def enforce_h2_emojis(html: str, flag: str) -> str:
    """
    WHERE mod çıktısında H2 emoji kurallarını deterministik uygula.
    AI ne yaparsa yapsın bu fonksiyon sonucu garanti eder.

    Kurallar:
      "Gezi Rehberi"   → sonunda bayrak emoji (flag)
      "Nasıl Bir Yer"  → sonunda bayrak emoji (flag)
      "Gezilecek Yerler" → sonunda 📌
    """
    def _h2_ensure_suffix(html_in: str, keyword: str, suffix: str) -> str:
        """keyword içeren her H2'nin sonuna suffix ekler (yoksa)."""
        def replacer(m):
            open_tag, inner, close_tag = m.group(1), m.group(2), m.group(3)
            # <strong> içeriğini bul
            sm = re.search(r'(<strong>)(.*?)(</strong>)', inner, re.DOTALL)
            if sm:
                text_in_strong = sm.group(2)
                # Mevcut suffix yoksa ekle
                stripped = text_in_strong.rstrip()
                if not stripped.endswith(suffix):
                    # Trailing emojileri temizle, sonra suffix ekle
                    stripped_clean = re.sub(
                        r'[\U00002600-\U000027BF\U0001F300-\U0001FAFF\s]+$',
                        '', stripped
                    ).rstrip()
                    new_strong_inner = stripped_clean + ' ' + suffix
                    inner_new = (inner[:sm.start(2)]
                                 + new_strong_inner
                                 + inner[sm.end(2):])
                    return open_tag + inner_new + close_tag
                return m.group(0)
            else:
                # <strong> yok — düz metin
                stripped = inner.rstrip()
                if not stripped.endswith(suffix):
                    stripped_clean = re.sub(
                        r'[\U00002600-\U000027BF\U0001F300-\U0001FAFF\s]+$',
                        '', stripped
                    ).rstrip()
                    return open_tag + stripped_clean + ' ' + suffix + close_tag
                return m.group(0)

        pattern = re.compile(
            r'(<h2[^>]*>)((?:(?!</h2>).)*?' + re.escape(keyword) + r'(?:(?!</h2>).)*?)(</h2>)',
            re.DOTALL | re.IGNORECASE
        )
        return pattern.sub(replacer, html_in)

    if flag:
        html = _h2_ensure_suffix(html, "Gezi Rehberi",  flag)
        html = _h2_ensure_suffix(html, "Nasıl Bir Yer", flag)
    html = _h2_ensure_suffix(html, "Gezilecek Yerler", "📌")
    return html

# ─── GÖRSEL WRAPPER (Where.txt §2 & §8) ──────────────────────────────────────
def img_wrapper(src: str, alt: str) -> str:
    """Standart resim sarıcı. loading='lazy' YOK - LiteSpeed halleder."""
    return (
        '<div style="text-align: center; width: 100%; margin: 30px auto;">\n'
        f'    <img src="{src}" alt="{alt}" '
        'style="display: inline-block; max-width: 100%; height: auto;" />\n'
        '</div>'
    )

def distribute_images(images: list[dict], sections: list[str], start: int = 2) -> list[str]:
    """
    3. fotoğraftan itibaren kalan fotoğrafları bölümler arasına dağıt.
    start: kaçıncı indexten başlanacak (0-tabanlı, default=2 yani 3. foto)
    Her 2 bölümde bir bir fotoğraf ekler.
    """
    remaining = images[start:]
    if not remaining:
        return sections
    result = list(sections)
    inserted = 0
    img_idx = 0
    i = 2  # ilk 2 section (giriş + 1.foto) sonrasından başla
    while img_idx < len(remaining) and i < len(result) - 2:
        # Her 2 bölümde bir fotoğraf (schema/faq gibi son bölümlere ekleme)
        if inserted % 1 == 0 and result[i].strip():
            img = remaining[img_idx]
            result.insert(i + 1, img_wrapper(img["src"], img["alt"] or "Fotoğraf"))
            img_idx += 1
            i += 3  # yerleştirilen + 2 section atla
        else:
            i += 2
        inserted += 1
    return result

def extract_all_images(html: str) -> list[dict]:
    """
    HTML'den tüm resimleri çıkar → [{'src':..., 'alt':...}, ...]
    figure, img, wp:html içindekileri yakala
    """
    images = []
    # figure > img
    for fig in re.finditer(r'<figure[^>]*>(.*?)</figure>', html,
                           re.DOTALL|re.IGNORECASE):
        img_m = re.search(r'<img[^>]*>', fig.group(1), re.IGNORECASE)
        if img_m:
            src = re.search(r'src="([^"]*)"', img_m.group(0))
            alt = re.search(r'alt="([^"]*)"', img_m.group(0))
            if src:
                images.append({
                    'src': src.group(1),
                    'alt': alt.group(1) if alt else '',
                    'original': fig.group(0)
                })
    # loose img (figure dışında)
    for img_m in re.finditer(r'<img[^>]*>', html, re.IGNORECASE):
        src = re.search(r'src="([^"]*)"', img_m.group(0))
        alt = re.search(r'alt="([^"]*)"', img_m.group(0))
        if src:
            already = any(i['src'] == src.group(1) for i in images)
            if not already:
                images.append({
                    'src': src.group(1),
                    'alt': alt.group(1) if alt else '',
                    'original': img_m.group(0)
                })
    return images

def remove_all_images(html: str) -> str:
    """Tüm resim elementlerini içerikten kaldır (yeniden yerleştirme için)"""
    html = re.sub(r'<figure[^>]*>.*?</figure>', '', html,
                  flags=re.DOTALL|re.IGNORECASE)
    html = re.sub(r'<!--\s*wp:html\s*-->.*?<!--\s*/wp:html\s*-->', '', html,
                  flags=re.DOTALL)
    html = re.sub(r'<img[^>]*>', '', html, flags=re.IGNORECASE)
    return html



