AI_ENGINE = "claude"  # "claude" | "gpt" | "auto"

def set_ai_engine(engine: str):
    """
    AI motorunu seç
    
    Args:
        engine: "claude", "gpt", veya "auto" (otomatik fallback)
    """
    global AI_ENGINE
    AI_ENGINE = engine.lower()
    
    engine_names = {
        "claude": "🔵 Claude Sonnet 4",
        "gpt": "🟢 GPT-4o (4x API Key)",
        "auto": "🔄 Auto (Claude → GPT fallback)"
    }
    
    print(f"   🤖 Engine: {engine_names.get(AI_ENGINE, AI_ENGINE)}")


