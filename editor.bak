def get_country_info(dest: str) -> str:
    """
    Destinasyon adına göre kısa ülke/bölge tanımı döndürür.
    Haritada yoksa Claude'a sorarak dinamik üretir.
    """
    # Direkt eşleşme
    if dest in _COUNTRY_INFO:
        return _COUNTRY_INFO[dest]
    # Kısmi eşleşme (büyük/küçük harf bağımsız)
    for key, val in _COUNTRY_INFO.items():
        if key.lower() in dest.lower() or dest.lower() in key.lower():
            return val
    # Claude fallback — ülke/bölge bilgisini sor
    try:
        raw_hint = ask_ai(
            f"'{dest}' sehrinin/ulkesinin bagli oldugu ulke ve bolge nedir? "
            f"Sadece kisa bir tanim yaz, maksimum 10 kelime. "
            f"Ornek: 'Orta Asya nin kalbi Kirgizistan' gibi.",
            max_tokens=60
        ).strip()
        # HTML tag, satır başı, tırnak temizle
        hint = re.sub(r'<[^>]+>', '', raw_hint).strip()
        hint = re.sub(r'[\n\r]+', ' ', hint).strip().strip('"').strip("'")
        return hint if hint else f"{dest} sehri"
    except Exception:
        return f"{dest} şehri"


def build_yoast_meta(dest: str, location_hint: str = "") -> tuple[str, str]:
    """
    (yoast_title, yoast_desc) döndür.
    Hedef: desc 150-155 karakter, max 158.
    location_hint boşsa get_country_info() ile otomatik alır.
    """
    yoast_title = f"{dest} Nasıl Bir Yer? Nerede, Nasıl Gidilir, Gezi Planı"

    if not location_hint:
        location_hint = get_country_info(dest)

    # Şablon (belge örneğiyle birebir):
    # "Kırgızistan nerede, nasıl gidilir? Orta Asya'nın kalbi Kırgızistan.
    #  Kırgızistan nasıl bir yer, ulaşım seçenekleri ve gezi planı rehberi."
    # Lokasyon hint'inden HTML ve satır başı temizle
    location_hint = re.sub(r'<[^>]+>', '', location_hint).strip()
    location_hint = re.sub(r'[\n\r]+', ' ', location_hint).strip()
    base = (
        f"{dest} nerede, nasıl gidilir? "
        f"{location_hint} {dest}. "
        f"{dest} nasıl bir yer, ulaşım seçenekleri ve gezi planı rehberi."
    )

    # 120-158 karakter aralığı hedefi
    if len(base) > 158:
        # Kelime sınırında kes, nokta ekle
        cut = base[:154].rsplit(' ', 1)[0].rstrip('.,')
        yoast_desc = cut + '...'
    elif len(base) < 120:
        # Çok kısa — "Gezi planı ve pratik ipuçları." ekle (rehber tekrarından kaçın)
        ext = " Gezi planı ve pratik ipuçları."
        candidate = base.rstrip('.') + ext
        if len(candidate) <= 158:
            yoast_desc = candidate
        else:
            yoast_desc = base  # uzadıysa dokunma
    else:
        yoast_desc = base

    return yoast_title, yoast_desc




# ============================================================
# DIL_KURALLARI — Tüm modlarda geçerli merkezi dil & stil kuralı
# WHERE / TRAVEL / GUIDE — tek kaynak
# ============================================================
DIL_KURALLARI = """
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
DIL, ANLATIM VE STİL — TÜM MODLAR İÇİN
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

YAZIM DILI:
- Simdiki zaman (tarihi anlatimlarda bile): "gidiyor, dönüşüyor, çıkıyor"
- Ben dili (ölçülü): "fark ettim", "ilk baktığımda", "durakladım"
- Kısa cümle + somut sayı: "37 metre", "8. yüzyıl", nüfus
- Duyusal detay (1-2 tane seç): ışık / ses / koku / doku / renk — somut, abartısız

GÖSTER-SÖYLE PRENSİBİ:
- ASLA "güzel/etkileyici/muhteşem" → GÖSTER: "Taş sokakta gölge yok, öğle sıcağından kaçacak yer yok."
- Gerçekçi gözlem: "Esnaf ilgisiz; turistlerle dolu şehrin yorgunluğu var."
- Romantize etme
- SOYUT DUYGU CÜMLESİ KURMA: "Geçmişi hissedebilirsiniz", "tarihin izinde yürüyebilirsiniz", "kendinizi kaptırın" YASAK.
  Bunun yerine somut nesne, sayı veya eylem yaz:
  ❌ "Her adımda geçmişin yansımasını hissedebileceğiniz bir sokak."
  ✅ "Sokakta iki adımda bir farklı dönemden yapı var: Osmanlı hamamı, Venedik çan kulesi, Avusturya postanesi."

DRAMATİK ANLATIMDAN KAÇIN:
  YANLIŞ → DOĞRU
  "Büyüleyici manzara, nefesimi kesti" → "Tepeden şehrin tamamını görebiliyorsunuz"
  "Zamanın durduğu masalsı yer" → "Sokakları taş döşeli, evler eski ama bakımlı"
  "Cennetten bir köşe" → "Deniz o kadar temizdi ki dibi görünüyordu"
  "Dar sokakları, renkli evleriyle..." → "Sokaklar 2 metre genişliğinde, araba giremez"
  "Açık hava müzesi gibi" → "Her köşede tarihi yapı var, eski kent planı korunmuş"

YASAK KELİMELER:
  muhteşem, harika, eşsiz, inanılmaz, mükemmel, şaşırtıcı, benzersiz,
  olağanüstü, nefes kesici, büyülü, fantastik, göz alıcı, mücevher,
  kadim, görkemli, nefis, dikkat çekiyor, etkileyici, misafirperver,
  Metro Turizm, Turkish Airlines

YASAK CÜMLE KALIPLARI:
  "Kendi yolunu bulur..." / "Kadar gösterişli değil ama..." /
  "Dar sokakları, renkli evleriyle..." / "Açık hava müzesi..." /
  "Binbir gece masallarından..." / "Zaman yolculuğuna çıkar..." /
  "Tarihin izlerini hissed..." / "Kaybolmanın keyfine..." /
  "Davet ediyorum" / "Tadını çıkarın" / "Unutmayın"

YASAK YAPI:
  - Tire "—" veya "–" (H3 başlığında serbest)
  - <ul><li> liste etiketleri → paragrafa çevir
  - ## ### Markdown → Gutenberg HTML kullan
  - Koordinat, enlem, boylam

BOLD KURALI:
  - H2/H3 altındaki ilk destinasyon veya yer adı → <strong>bold</strong>
  - Sayılar bold OLMAZ (giriş ücreti, mesafe gibi pratik bilgiler hariç)
  - Her paragrafta maksimum 1-2 bold
  - Yer/yapı adı ilk geçtiğinde bold, tekrarda değil
  - Tüm cümleyi bold yapmak YASAK

GPT İÇİN ANLATI DENGESİ:
  GPT'nin bilgi ağırlıklı bölümlerde (Nasıl Bir Yer, Nerede, Nasıl Gidilir, Gezilecek Yerler, Gezi Planı):
  %30 → Dergi yazısı anlatımı (akıcı, betimleyici, atmosferik)
  %70 → Gerçekçi, bilgilendirici, pratik anlatım
  ÖRNEK DENGELİ CÜMLE: "Karl Köprüsü sabahın köründe tenha. Taş döşeme ıslak, 
  nehirden soğuk rüzgar vuruyor. Sabah 7'de gidersen turist kalabalığından önce 
